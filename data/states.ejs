<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <style>
    .breadcrumb{max-width:1000px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db;font-size:.75rem}
    .states-page{max-width:1000px;margin:0 auto;padding:0 24px 60px}
    .states-header{padding:28px 0 32px;border-bottom:1px solid #e5e7eb;margin-bottom:32px}
    .page-eyebrow{display:inline-flex;align-items:center;gap:6px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:4px 12px;margin-bottom:12px}
    .states-header h1{font-size:clamp(1.7rem,4vw,2.2rem);font-weight:800;line-height:1.2;margin:0 0 10px;color:#111827}
    .states-header p{font-size:1.05rem;color:#6b7280;margin:0;max-width:640px;line-height:1.5}
    .states-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    @media(max-width:900px){.states-grid{grid-template-columns:repeat(3,1fr)}}
    @media(max-width:640px){.states-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:400px){.states-grid{grid-template-columns:1fr}}
    .state-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:14px 16px;text-decoration:none;color:inherit;transition:all .15s;display:flex;align-items:center;justify-content:space-between;gap:8px}
    .state-card:hover{border-color:#16a34a;box-shadow:0 4px 12px rgba(22,163,74,.04);transform:translateY(-1px)}
    .state-name{font-size:.95rem;font-weight:600;color:#111827}
    .state-meta{font-size:.75rem;color:#9ca3af;font-weight:600;background:#f3f4f6;border-radius:4px;padding:2px 6px;flex-shrink:0}
    .state-card:hover .state-name{color:#16a34a}
    .ad-zone{text-align:center;margin:28px 0;min-height:120px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    /* Featured states */
    .featured-section{margin:0 0 40px}
    .section-heading{font-size:1.15rem;font-weight:800;color:#111827;margin:0 0 16px}
    .featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:40px}
    @media(max-width:720px){.featured-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:440px){.featured-grid{grid-template-columns:1fr}}
    .featured-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:18px 20px;text-decoration:none;color:inherit;transition:all .15s;display:flex;flex-direction:column;gap:6px}
    .featured-card:hover{border-color:#16a34a;box-shadow:0 6px 18px rgba(22,163,74,.07);transform:translateY(-2px)}
    .featured-card-top{display:flex;align-items:center;gap:10px}
    .featured-flag{font-size:1.4rem;line-height:1}
    .featured-name{font-size:1rem;font-weight:700;color:#111827}
    .featured-rate{font-size:.8rem;font-weight:600;color:#16a34a;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:2px 8px;width:fit-content}
    .featured-desc{font-size:.82rem;color:#6b7280;line-height:1.5;margin:0}
    /* No-tax callout strip */
    .notax-strip{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:18px 22px;margin-bottom:32px}
    .notax-strip h2{font-size:1rem;font-weight:700;color:#111827;margin:0 0 10px}
    .notax-links{display:flex;flex-wrap:wrap;gap:8px}
    .notax-link{font-size:.85rem;font-weight:600;color:#15803d;background:#fff;border:1px solid #bbf7d0;border-radius:8px;padding:5px 12px;text-decoration:none;transition:all .12s}
    .notax-link:hover{background:#dcfce7;border-color:#16a34a}
    /* FAQ */
    .states-faq{margin:40px 0 0}
    .states-faq h2{font-size:1.25rem;font-weight:800;color:#111827;margin:0 0 20px}
    .faq-accordion{display:flex;flex-direction:column;gap:10px}
    .faq-acc-item{background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}
    .faq-acc-btn{width:100%;background:none;border:none;padding:16px 20px;text-align:left;font-size:.92rem;font-weight:600;color:#111827;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;font-family:inherit}
    .faq-acc-btn:hover{background:#f9fafb}
    .faq-acc-chevron{min-width:20px;height:20px;border-radius:50%;background:#f3f4f6;display:flex;align-items:center;justify-content:center;transition:transform .2s;flex-shrink:0}
    .faq-acc-item.open .faq-acc-chevron{transform:rotate(180deg);background:#dcfce7}
    .faq-acc-answer{display:none;padding:0 20px 16px;font-size:.88rem;color:#4b5563;line-height:1.65}
    .faq-acc-item.open .faq-acc-answer{display:block}
    .faq-acc-answer a{color:#16a34a;font-weight:600;text-decoration:none}
    .faq-acc-answer a:hover{text-decoration:underline}
    /* Guide content */
    .states-guide{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:28px 32px;margin:32px 0}
    @media(max-width:600px){.states-guide{padding:20px 18px}}
    .states-guide h2{font-size:1.2rem;font-weight:800;color:#111827;margin:0 0 14px}
    .states-guide p{font-size:.92rem;color:#4b5563;line-height:1.7;margin:0 0 14px}
    .states-guide p:last-child{margin:0}
    .states-guide a{color:#16a34a;font-weight:600;text-decoration:none}
    .states-guide a:hover{text-decoration:underline}
    .states-guide ul{font-size:.92rem;color:#4b5563;line-height:1.7;padding-left:20px;margin:0 0 14px;display:flex;flex-direction:column;gap:8px}
    .states-guide ul li strong{color:#111827}
    /* comparison table */
    .compare-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;border-radius:10px;border:1px solid #e5e7eb;margin:16px 0}
    .compare-table{width:100%;border-collapse:collapse;font-size:.88rem;min-width:420px}
    .compare-table thead{background:#16a34a;color:#fff}
    .compare-table thead th{padding:.65rem 1rem;text-align:left;font-weight:600;white-space:nowrap}
    .compare-table tbody tr:nth-child(even){background:#f9fafb}
    .compare-table tbody tr:hover{background:#f0fdf4}
    .compare-table tbody td{padding:.6rem 1rem;color:#111827;border-bottom:1px solid #f3f4f6}
    .compare-table .rate-high{color:#dc2626;font-weight:700}
    .compare-table .rate-zero{color:#16a34a;font-weight:700}
    .compare-table .rate-mid{color:#d97706;font-weight:600}
  </style>
</head>
