  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the self-employment tax rate for 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 2026 self-employment tax rate is 15.3% on 92.35% of net self-employment earnings: 12.4% for Social Security on net earnings up to the projected wage base of approximately $180,400, and 2.9% for Medicare on all net earnings with no cap. Self-employed individuals can deduct half of SE tax as an above-the-line adjustment to income."
        }
      },
      {
        "@type": "Question",
        "name": "Did the self-employment tax rate change for 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The SE tax rate of 15.3% (12.4% Social Security plus 2.9% Medicare) is unchanged for 2026. The Social Security wage base, which caps the 12.4% Social Security portion, is projected to increase to approximately $180,400 from $176,100 in 2025. Official confirmation is expected from the SSA in October 2026."
        }
      },
      {
        "@type": "Question",
        "name": "Why is SE tax calculated on 92.35% of net earnings?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 92.35% factor (1 minus 0.0765) gives self-employed individuals an adjustment equivalent to the employer-side FICA deduction that W-2 employees receive automatically. Employees only pay FICA on their wages, not on the employer's matching contribution. The 92.35% rule approximates the same treatment for self-employed workers."
        }
      },
      {
        "@type": "Question",
        "name": "Can I deduct self-employment tax in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can deduct 50% of your self-employment tax as an above-the-line adjustment to income on Form 1040 Schedule 1. This deduction reduces your adjusted gross income (AGI) and therefore your federal income tax, but it does not reduce the SE tax itself. You do not need to itemize to take this deduction."
        }
      }
    ]
  }
