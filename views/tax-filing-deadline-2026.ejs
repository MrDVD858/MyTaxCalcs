            <div class="dl-sub">Only if you filed Form 4868 by April 15</div>
          </div>
          <div class="deadline-item">
            <div class="dl-label">Payment Deadline</div>
            <div class="dl-date">April 15, 2026</div>
            <div class="dl-sub">Extensions do NOT extend time to pay</div>
          </div>
          <div class="deadline-item">
            <div class="dl-label">Refund Claim Deadline</div>
            <div class="dl-date">April 15, 2029</div>
            <div class="dl-sub">3-year limit to claim a 2025 refund</div>
          </div>
        </div>
      </div>

