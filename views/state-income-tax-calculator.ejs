<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= state.name %> Income Tax Calculator | MyTaxCalcs</title>
  <meta name="description" content="Free <%= state.name %> income tax calculator. <%= state.hasIncomeTax ? "State income tax rates: " + state.brackets + "." : state.name + " has no state income tax." %> Estimate your federal and state tax for 2024.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="<%= state.name %> Income Tax Calculator | MyTaxCalcs">
  <meta property="og:description" content="Free <%= state.name %> income tax calculator. Estimate your federal and state taxes for 2024.">
  <meta property="og:url" content="https://mytaxcalcs.com/<%= state.slug %>-income-tax-calculator">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "<%= state.name %> Income Tax Calculator",
    "url": "https://mytaxcalcs.com/<%= state.slug %>-income-tax-calculator",
    "description": "Free <%= state.name %> income tax calculator to estimate federal income tax and review state tax information.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/california-income-tax-calculator">States</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
    </nav>
  </header>

  <section class="calc-hero">
    <div class="calc-hero-inner">
      <div class="section-label"><%= state.name %> Tax Estimator</div>
      <h1><%= state.name %> Income Tax Calculator</h1>
      <% if (state.hasIncomeTax) { %>
        <p>Estimate your federal income tax as a <%= state.name %> resident. <%= state.name %> state income tax rates: <strong style="color:#4ade80;"><%= state.brackets %></strong>.</p>
      <% } else { %>
        <p><%= state.name %> has no broad-based state income tax. Estimate your federal income tax below.</p>
      <% } %>
    </div>
  </section>

  <main class="calc-main">
    <div class="calc-layout">

      <section class="calc-form-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#ecfdf5; color:#16a34a;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h4M7 12h8"/></svg>
          </div>
          <h2>Your Tax Information</h2>
        </div>
        <form method="POST" action="/<%= state.slug %>-income-tax-calculator" class="calc-form">
          <div class="form-group">
            <label>Gross Annual Income</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="grossIncome" value="<%= form.grossIncome || '' %>" placeholder="85,000" required></div>
          </div>
          <div class="form-group">
            <label>Filing Status</label>
            <select name="filingStatus">
              <option value="single" <%= form.filingStatus === 'single' ? 'selected' : '' %>>Single</option>
              <option value="marriedJoint" <%= form.filingStatus === 'marriedJoint' ? 'selected' : '' %>>Married Filing Jointly</option>
              <option value="marriedSeparate" <%= form.filingStatus === 'marriedSeparate' ? 'selected' : '' %>>Married Filing Separately</option>
              <option value="headHousehold" <%= form.filingStatus === 'headHousehold' ? 'selected' : '' %>>Head of Household</option>
            </select>
          </div>
          <div class="form-group">
            <label>Deduction Type</label>
            <select name="deductionType">
              <option value="standard" <%= form.deductionType === 'standard' ? 'selected' : '' %>>Standard Deduction</option>
              <option value="itemized" <%= form.deductionType === 'itemized' ? 'selected' : '' %>>Itemized Deduction</option>
            </select>
          </div>
          <div class="form-group">
            <label>Itemized Deduction Amount</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="itemizedDeduction" value="<%= form.itemizedDeduction || '' %>" placeholder="0"></div>
          </div>
          <div class="form-group">
            <label>Federal Tax Withheld</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="federalWithheld" value="<%= form.federalWithheld || '' %>" placeholder="12,000"></div>
          </div>
          <div class="form-group">
            <label>Tax Credits</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="taxCredits" value="<%= form.taxCredits || '' %>" placeholder="0"></div>
          </div>
          <button type="submit" class="calc-submit-btn">
            Calculate Estimate
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </section>

      <section class="calc-results-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#f0fdf4; color:#16a34a;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h2>Estimated Results</h2>
        </div>
        <% if (!result) { %>
          <div class="results-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <p>Enter your information to see your estimate.</p>
          </div>
        <% } else { %>
          <div class="results-grid">
            <div class="result-row"><span>Gross Income</span><strong>$<%= Math.round(result.grossIncome).toLocaleString() %></strong></div>
            <div class="result-row"><span>Deduction</span><strong>$<%= Math.round(result.deduction).toLocaleString() %></strong></div>
            <div class="result-row"><span>Taxable Income</span><strong>$<%= Math.round(result.taxableIncome).toLocaleString() %></strong></div>
            <div class="result-row"><span>Federal Tax After Credits</span><strong>$<%= Math.round(result.federalTaxAfterCredits).toLocaleString() %></strong></div>
            <div class="result-row">
              <span><%= state.name %> State Tax</span>
              <% if (state.hasIncomeTax) { %>
                <strong style="color:var(--muted);">Coming soon</strong>
              <% } else { %>
                <strong>$0</strong>
              <% } %>
            </div>
            <div class="result-row result-highlight <%= result.refundOrOwed >= 0 ? 'refund' : 'owed' %>">
              <% if (result.refundOrOwed >= 0) { %>
                <span>Est. Federal Refund</span>
                <strong>$<%= Math.round(result.refundOrOwed).toLocaleString() %></strong>
              <% } else { %>
                <span>Est. Federal Amount Owed</span>
                <strong>$<%= Math.abs(Math.round(result.refundOrOwed)).toLocaleString() %></strong>
              <% } %>
            </div>
            <div class="result-row"><span>Effective Tax Rate</span><strong><%= (result.effectiveTaxRate * 100).toFixed(1) %>%</strong></div>
            <div class="result-row"><span>Marginal Tax Rate</span><strong><%= (result.marginalRate * 100).toFixed(1) %>%</strong></div>
          </div>
        <% } %>
        <div class="results-disclaimer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Estimate only. Not tax, legal, accounting, or financial advice.
        </div>
      </section>

    </div>

    <div class="calc-content-wrapper">
      <section class="content seo-content">
        <p class="eyebrow dark"><%= state.name %> Tax Calculator Guide</p>
        <h2>About this <%= state.name %> income tax calculator</h2>
        <% if (state.hasIncomeTax) { %>
          <p>This <%= state.name %> income tax calculator page helps users estimate federal income tax while reviewing state-specific tax information. State income tax rules can vary by filing status, deductions, credits, taxable income, and local rules, so the state estimate should be treated as a planning estimate only.</p>
          <div style="background:#f0fdf4;border:1px solid rgba(34,197,94,0.25);border-left:4px solid #22c55e;border-radius:8px;padding:16px 20px;margin:20px 0;">
            <p style="margin:0;font-size:0.9rem;color:#0f172a;"><strong><%= state.name %> State Income Tax:</strong> <%= state.note %></p>
            <p style="margin:8px 0 0;font-size:0.85rem;color:#64748b;">Tax rate range: <strong><%= state.brackets %></strong> &nbsp;|&nbsp; Top rate: <strong><%= state.topRate %>%</strong></p>
          </div>
        <% } else { %>
          <p><%= state.name %> does not have a broad-based state income tax. This page focuses on estimating federal income tax while showing that the state income tax estimate is $0 for broad-based state income tax purposes.</p>
          <div style="background:#f0fdf4;border:1px solid rgba(34,197,94,0.25);border-left:4px solid #22c55e;border-radius:8px;padding:16px 20px;margin:20px 0;">
            <p style="margin:0;font-size:0.9rem;color:#0f172a;"><strong><%= state.name %> Tax Note:</strong> <%= state.noTaxNote %></p>
          </div>
        <% } %>

        <div class="seo-grid">
          <div class="seo-mini-card">
            <h3>Federal estimate</h3>
            <p>The calculator estimates federal taxable income, federal tax after credits, refund or amount owed, and related federal tax details.</p>
          </div>
          <div class="seo-mini-card">
            <h3><%= state.name %> tax note</h3>
            <% if (state.hasIncomeTax) { %>
              <p><%= state.name %> has state-specific income tax rules that may require additional deductions, exemptions, credits, or state tax tables.</p>
            <% } else { %>
              <p><%= state.name %> does not have a broad-based state income tax, but residents may still pay other taxes such as sales tax, property tax, or local taxes.</p>
            <% } %>
          </div>
          <div class="seo-mini-card">
            <h3>Estimate only</h3>
            <p>Results are for educational planning only and should not be used as tax, legal, accounting, or financial advice.</p>
          </div>
        </div>

        <h2><%= state.name %> income tax FAQ</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3>Does <%= state.name %> have state income tax?</h3>
            <% if (state.hasIncomeTax) { %>
              <p>Yes. <%= state.name %> has state income tax rules that may apply to residents and some nonresidents. The final amount can depend on income, filing status, deductions, credits, and state-specific rules.</p>
            <% } else { %>
              <p><%= state.name %> does not have a broad-based state income tax. However, residents may still owe federal income tax and may pay other types of state or local taxes.</p>
            <% } %>
          </div>
          <div class="faq-item">
            <h3>Does this calculator include all <%= state.name %> tax rules?</h3>
            <p>No. This calculator is designed for simple estimates. It may not include every state deduction, credit, exemption, local tax rule, or special tax situation.</p>
          </div>
          <div class="faq-item">
            <h3>Why does my refund or amount owed change?</h3>
            <p>Your estimate changes when income, filing status, deductions, withholding, or credits change. Withholding is especially important because it affects whether the calculator shows a refund or an amount owed.</p>
          </div>
          <div class="faq-item">
            <h3>Can I use this for tax filing?</h3>
            <p>No. This page is for planning and educational estimates only. For filing, use official tax forms, tax software, or a qualified tax professional.</p>
          </div>
          <div class="faq-item">
            <h3>What should I check after using this calculator?</h3>
            <p>Review your filing status, income, withholding, credits, deductions, and any state-specific tax rules that may apply to your situation.</p>
          </div>
        </div>
        <p class="last-updated">Last updated: April 2026</p>
      </section>

      <section class="content">
        <div class="section-header" style="text-align:left; margin-bottom:24px;">
          <div class="section-label">All 50 States</div>
          <h2 style="font-size:1.5rem; margin:8px 0 6px;">All State Calculators</h2>
        </div>
        <div class="state-list">
          <% states.forEach(function(item) { %>
            <a href="/<%= item.slug %>-income-tax-calculator"><%= item.name %></a>
          <% }) %>
        </div>
      </section>
    </div>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/california-income-tax-calculator">State Tax Calculators</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom"><p>© 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>
</body>
</html>
