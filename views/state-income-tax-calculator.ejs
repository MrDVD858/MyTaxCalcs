<%- include('partials/header', {
  pageTitle: state.name + ' Income Tax Calculator 2025 | MyTaxCalcs',
  metaDescription: state.hasIncomeTax
    ? 'Free ' + state.name + ' income tax calculator for 2025. Estimate state and federal income tax, effective rate, and take-home pay. Includes ' + state.name + ' tax brackets and worked examples.'
    : state.name + ' has no state income tax. Use our free calculator to estimate your federal income tax as a ' + state.name + ' resident for 2025.',
  canonicalUrl: 'https://mytaxcalcs.com/' + state.slug + '-income-tax-calculator',
  ogTitle: state.name + ' Income Tax Calculator 2025 | MyTaxCalcs',
  ogDescription: state.hasIncomeTax
    ? 'Estimate your ' + state.name + ' state and federal income tax for 2025. Includes bracket table and worked dollar example.'
    : state.name + ' has no state income tax. Estimate your federal tax liability as a ' + state.name + ' resident.',
  ogUrl: 'https://mytaxcalcs.com/' + state.slug + '-income-tax-calculator'
}) %>

<main>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-nav" aria-label="Breadcrumb">
    <ol class="breadcrumb">
      <li><a href="/">Home</a></li>
      <li><a href="/states">State Calculators</a></li>
      <li aria-current="page"><%= state.name %> Income Tax Calculator</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="calculator-hero">
    <div class="hero-badge"><%= state.abbr %> State Tax</div>
    <h1><%= state.name %> Income Tax Calculator</h1>
    <% if (state.hasIncomeTax) { %>
      <p class="hero-sub">Estimate your 2025 <%= state.name %> state income tax and federal income tax. Includes <%= state.name %> tax brackets, a worked dollar example, and filing tips.</p>
    <% } else { %>
      <p class="hero-sub"><%= state.name %> has no state income tax. Use this calculator to estimate your federal income tax liability as a <%= state.name %> resident.</p>
    <% } %>
  </section>

  <!-- Ad: Top -->
  <div class="ad-slot ad-top">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-5193834725888549"
         data-ad-slot="4212978293"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Key Facts Bar -->
  <section class="key-facts-bar">
    <div class="fact-item">
      <span class="fact-label">State Income Tax</span>
      <span class="fact-value"><%= state.hasIncomeTax ? state.brackets : 'None' %></span>
    </div>
    <div class="fact-item">
      <span class="fact-label">Top Rate</span>
      <span class="fact-value"><%= state.hasIncomeTax ? state.topRate + '%' : '0%' %></span>
    </div>
    <div class="fact-item">
      <span class="fact-label">Tax Type</span>
      <span class="fact-value">
        <% if (!state.hasIncomeTax) { %>No Income Tax
        <% } else if (state.topRate === state.bottomRate) { %>Flat Rate
        <% } else { %>Graduated<% } %>
      </span>
    </div>
    <div class="fact-item">
      <span class="fact-label">Official Source</span>
      <span class="fact-value"><a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a></span>
    </div>
  </section>

  <!-- State Overview -->
  <section class="state-overview-section">
    <h2><%= state.name %> State Income Tax Overview</h2>
    <p><%= state.overview %></p>
  </section>

  <!-- Bracket Table OR No-Tax Callout -->
  <% if (state.hasIncomeTax && state.bracketRows && state.bracketRows.length > 0) { %>
  <section class="bracket-section">
    <h2><%= state.name %> Income Tax Brackets (2025)</h2>
    <p>These are the <%= state.name %> state income tax brackets for single filers in 2025. Your tax is calculated progressively — only the income within each bracket is taxed at that bracket's rate.</p>
    <div class="bracket-table-wrap">
      <table class="bracket-table">
        <thead>
          <tr>
            <th>Taxable Income</th>
            <th>Tax Rate</th>
          </tr>
        </thead>
        <tbody>
          <% state.bracketRows.forEach(function(row) { %>
          <tr>
            <td>
              <% if (row.max === null) { %>
                Over $<%= row.min.toLocaleString() %>
              <% } else { %>
                $<%= row.min.toLocaleString() %> – $<%= row.max.toLocaleString() %>
              <% } %>
            </td>
            <td><%= row.rate %>%</td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <p class="bracket-note">Source: <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a>. Brackets shown are for single filers. Married filing jointly thresholds may differ.</p>
  </section>

  <!-- Worked Dollar Example (graduated states) -->
  <section class="worked-example-section">
    <h2>What a <%= state.name %> Resident Actually Pays: A Worked Example</h2>
    <p>Understanding your effective tax rate is more useful than knowing your top bracket. Here's how the math works for a typical <%= state.name %> filer.</p>
    <div class="example-box">
      <div class="example-scenario">
        <strong>Scenario:</strong> Single filer with $65,000 in taxable income
      </div>
      <div class="example-calc" id="worked-example-<%= state.slug %>">
        <!-- Populated by inline script below -->
      </div>
    </div>
    <script>
    (function() {
      const brackets = <%- JSON.stringify(state.bracketRows) %>;
      const income = 65000;
      let tax = 0;
      let breakdown = [];
      for (let i = 0; i < brackets.length; i++) {
        const b = brackets[i];
        const lower = b.min;
        const upper = b.max === null ? income : Math.min(b.max, income);
        if (income <= lower) break;
        const taxable = upper - lower;
        const amount = taxable * (b.rate / 100);
        tax += amount;
        breakdown.push({ rate: b.rate, taxable: taxable, amount: amount });
      }
      const effectiveRate = ((tax / income) * 100).toFixed(1);
      const fmt = n => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

      let html = '<table class="example-table"><thead><tr><th>Bracket</th><th>Income in Bracket</th><th>Tax</th></tr></thead><tbody>';
      breakdown.forEach(function(r) {
        html += '<tr><td>' + r.rate + '%</td><td>' + fmt(r.taxable) + '</td><td>' + fmt(r.amount) + '</td></tr>';
      });
      html += '</tbody><tfoot><tr><td colspan="2"><strong>Total State Tax on $65,000</strong></td><td><strong>' + fmt(tax) + '</strong></td></tr>';
      html += '<tr><td colspan="2"><strong>Effective State Tax Rate</strong></td><td><strong>' + effectiveRate + '%</strong></td></tr></tfoot></table>';
      document.getElementById('worked-example-<%= state.slug %>').innerHTML = html;
    })();
    </script>
  </section>

  <% } else if (state.hasIncomeTax && state.topRate === state.bottomRate) { %>
  <!-- Flat rate state -->
  <section class="bracket-section">
    <h2><%= state.name %> Income Tax Rate (2025)</h2>
    <p><%= state.name %> uses a flat income tax rate — the same percentage applies to all taxable income regardless of how much you earn.</p>
    <div class="flat-rate-callout">
      <span class="flat-rate-number"><%= state.topRate %>%</span>
      <span class="flat-rate-label">Flat rate on all taxable income</span>
    </div>
    <p class="bracket-note">Source: <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a></p>
  </section>

  <section class="worked-example-section">
    <h2>What a <%= state.name %> Resident Actually Pays: A Worked Example</h2>
    <div class="example-box">
      <div class="example-scenario"><strong>Scenario:</strong> Single filer with $65,000 in taxable income</div>
      <div class="example-calc">
        <table class="example-table">
          <tbody>
            <tr>
              <td>Taxable Income</td>
              <td>$65,000</td>
            </tr>
            <tr>
              <td><%= state.name %> Flat Rate</td>
              <td><%= state.topRate %>%</td>
            </tr>
          </tbody>
          <tfoot>
            <tr>
              <td><strong>Estimated State Tax</strong></td>
              <td><strong>$<%= (65000 * state.topRate / 100).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></strong></td>
            </tr>
            <tr>
              <td><strong>Effective Rate</strong></td>
              <td><strong><%= state.topRate %>%</strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <% } else { %>
  <!-- No income tax state -->
  <section class="no-tax-callout-section">
    <div class="no-tax-callout">
      <div class="no-tax-icon">✓</div>
      <div>
        <h2><%= state.name %> Has No State Income Tax</h2>
        <p><%= state.noTaxNote %></p>
      </div>
    </div>
    <p>As a <%= state.name %> resident, your state income tax liability is $0. The calculator below estimates your <strong>federal</strong> income tax, which applies to all U.S. residents regardless of state.</p>
  </section>
  <% } %>

  <!-- Calculator Form -->
  <section class="calculator-card">
    <h2>Estimate Your <%= state.hasIncomeTax ? state.name + ' State +' : '' %> Federal Income Tax</h2>
    <form id="state-tax-form">
      <div class="form-group">
        <label for="gross-income">Gross Annual Income</label>
        <div class="input-prefix">$</div>
        <input type="number" id="gross-income" placeholder="0" min="0" step="1">
      </div>
      <div class="form-group">
        <label for="filing-status">Filing Status</label>
        <select id="filing-status">
          <option value="single">Single</option>
          <option value="mfj">Married Filing Jointly</option>
          <option value="mfs">Married Filing Separately</option>
          <option value="hoh">Head of Household</option>
        </select>
      </div>
      <div class="form-group">
        <label for="deduction-type">Deduction Type</label>
        <select id="deduction-type">
          <option value="standard">Standard Deduction</option>
          <option value="itemized">Itemized Deduction</option>
        </select>
      </div>
      <div class="form-group" id="itemized-group" style="display:none;">
        <label for="itemized-amount">Itemized Deduction Amount</label>
        <div class="input-prefix">$</div>
        <input type="number" id="itemized-amount" placeholder="0" min="0" step="1">
      </div>
      <div class="form-group">
        <label for="withholding">Federal Tax Withheld (YTD)</label>
        <div class="input-prefix">$</div>
        <input type="number" id="withholding" placeholder="0" min="0" step="1">
      </div>
      <div class="form-group">
        <label for="credits">Tax Credits</label>
        <div class="input-prefix">$</div>
        <input type="number" id="credits" placeholder="0" min="0" step="1">
      </div>
      <button type="button" id="calculate-btn" class="btn-primary">Calculate Tax Estimate</button>
    </form>

    <div id="results" class="results-panel" style="display:none;">
      <h3>Your Tax Estimate</h3>
      <div class="results-grid">
        <div class="result-item">
          <span class="result-label">Gross Income</span>
          <span class="result-value" id="r-gross">—</span>
        </div>
        <div class="result-item">
          <span class="result-label">Standard / Itemized Deduction</span>
          <span class="result-value" id="r-deduction">—</span>
        </div>
        <div class="result-item">
          <span class="result-label">Federal Taxable Income</span>
          <span class="result-value" id="r-taxable">—</span>
        </div>
        <div class="result-item">
          <span class="result-label">Federal Income Tax</span>
          <span class="result-value" id="r-federal-tax">—</span>
        </div>
        <% if (state.hasIncomeTax) { %>
        <div class="result-item">
          <span class="result-label"><%= state.name %> State Tax (Est.)</span>
          <span class="result-value" id="r-state-tax">—</span>
        </div>
        <% } %>
        <div class="result-item">
          <span class="result-label">Marginal Federal Rate</span>
          <span class="result-value" id="r-marginal">—</span>
        </div>
        <div class="result-item">
          <span class="result-label">Effective Federal Rate</span>
          <span class="result-value" id="r-effective">—</span>
        </div>
        <div class="result-item highlight">
          <span class="result-label">Estimated Refund / Amount Owed</span>
          <span class="result-value" id="r-refund">—</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator JS -->
  <script>
    // Show/hide itemized field
    document.getElementById('deduction-type').addEventListener('change', function() {
      document.getElementById('itemized-group').style.display = this.value === 'itemized' ? 'block' : 'none';
    });

    document.getElementById('calculate-btn').addEventListener('click', function() {
      const gross = parseFloat(document.getElementById('gross-income').value) || 0;
      const filingStatus = document.getElementById('filing-status').value;
      const deductionType = document.getElementById('deduction-type').value;
      const itemized = parseFloat(document.getElementById('itemized-amount').value) || 0;
      const withheld = parseFloat(document.getElementById('withholding').value) || 0;
      const credits = parseFloat(document.getElementById('credits').value) || 0;

      // 2025 Standard deductions
      const stdDeductions = { single: 15000, mfj: 30000, mfs: 15000, hoh: 22500 };
      const deduction = deductionType === 'itemized' ? itemized : stdDeductions[filingStatus];
      const taxableIncome = Math.max(0, gross - deduction);

      // 2025 Federal brackets
      const brackets = {
        single: [[11925,0.10],[48475,0.12],[103350,0.22],[197300,0.24],[250525,0.32],[626350,0.35],[Infinity,0.37]],
        mfj:    [[23850,0.10],[96950,0.12],[206700,0.22],[394600,0.24],[501050,0.32],[751600,0.35],[Infinity,0.37]],
        mfs:    [[11925,0.10],[48475,0.12],[103350,0.22],[197300,0.24],[250525,0.32],[375800,0.35],[Infinity,0.37]],
        hoh:    [[17000,0.10],[64850,0.12],[103350,0.22],[197300,0.24],[250500,0.32],[626350,0.35],[Infinity,0.37]]
      };

      let federalTax = 0, marginalRate = 0.10, prev = 0;
      for (const [threshold, rate] of brackets[filingStatus]) {
        if (taxableIncome <= prev) break;
        const chunk = Math.min(taxableIncome, threshold) - prev;
        federalTax += chunk * rate;
        marginalRate = rate;
        prev = threshold;
      }
      federalTax = Math.max(0, federalTax - credits);
      const effectiveRate = gross > 0 ? (federalTax / gross * 100).toFixed(1) : '0.0';
      const refund = withheld - federalTax;

      // State tax estimate (top-rate approximation for display)
      <% if (state.hasIncomeTax) { %>
      let stateTax = 0;
      <% if (state.bracketRows && state.bracketRows.length > 0) { %>
      const stateBrackets = <%- JSON.stringify(state.bracketRows) %>;
      for (let i = 0; i < stateBrackets.length; i++) {
        const b = stateBrackets[i];
        if (taxableIncome <= b.min) break;
        const upper = b.max === null ? taxableIncome : Math.min(b.max, taxableIncome);
        stateTax += (upper - b.min) * (b.rate / 100);
      }
      <% } else { %>
      stateTax = taxableIncome * (<%= state.topRate %> / 100);
      <% } %>
      <% } %>

      const fmt = v => '$' + v.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});

      document.getElementById('r-gross').textContent = fmt(gross);
      document.getElementById('r-deduction').textContent = fmt(deduction);
      document.getElementById('r-taxable').textContent = fmt(taxableIncome);
      document.getElementById('r-federal-tax').textContent = fmt(federalTax);
      <% if (state.hasIncomeTax) { %>
      document.getElementById('r-state-tax').textContent = fmt(stateTax);
      <% } %>
      document.getElementById('r-marginal').textContent = (marginalRate * 100).toFixed(0) + '%';
      document.getElementById('r-effective').textContent = effectiveRate + '%';
      const refundEl = document.getElementById('r-refund');
      refundEl.textContent = (refund >= 0 ? 'Refund: ' : 'Owed: ') + fmt(Math.abs(refund));
      refundEl.style.color = refund >= 0 ? '#16a34a' : '#dc2626';

      document.getElementById('results').style.display = 'block';
    });
  </script>

  <!-- Ad: Mid -->
  <div class="ad-slot ad-mid">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-5193834725888549"
         data-ad-slot="5205436277"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- FAQ -->
  <section class="faq-section">
    <h2>Frequently Asked Questions — <%= state.name %> Income Tax</h2>

    <% if (state.hasIncomeTax) { %>

    <div class="faq-item">
      <h3>Does <%= state.name %> have a state income tax?</h3>
      <p>Yes. <%= state.name %> imposes a state income tax with a <%= state.topRate === state.bottomRate ? 'flat rate of ' + state.topRate + '%' : 'top rate of ' + state.topRate + '%' %>. The state tax is separate from — and in addition to — your federal income tax obligation.</p>
    </div>

    <div class="faq-item">
      <h3>What is the <%= state.name %> income tax rate for 2025?</h3>
      <p>
        <% if (state.topRate === state.bottomRate) { %>
          <%= state.name %> uses a flat income tax rate of <%= state.topRate %>% on all taxable income. This rate applies regardless of income level or filing status.
        <% } else { %>
          <%= state.name %> uses a graduated income tax system with rates ranging from <%= state.bottomRate %>% to <%= state.topRate %>%. Higher income levels are taxed at progressively higher rates, but only the income within each bracket is taxed at that bracket's rate.
        <% } %>
      </p>
    </div>

    <div class="faq-item">
      <h3>Do I have to file a <%= state.name %> state tax return?</h3>
      <p>Most full-year <%= state.name %> residents with income above the state's filing threshold must file a state tax return. Part-year residents and nonresidents with <%= state.name %> source income may also be required to file. Check the <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a> for the current filing thresholds and requirements.</p>
    </div>

    <div class="faq-item">
      <h3>Is this calculator exact for <%= state.name %> taxes?</h3>
      <p>No — this is an estimate. The state tax result uses <%= state.name %>'s tax brackets but does not account for all state-specific deductions, credits, exemptions, local taxes, or individual circumstances. Always verify your final figures using official <%= state.name %> tax forms or a qualified tax professional.</p>
    </div>

    <div class="faq-item">
      <h3>Does this calculator include federal income tax?</h3>
      <p>Yes. The calculator estimates both your <%= state.name %> state income tax and your federal income tax using 2025 federal brackets. The results show each separately so you can see your full combined tax picture.</p>
    </div>

    <div class="faq-item">
      <h3>Where can I find official <%= state.name %> tax forms and instructions?</h3>
      <p>The official source for <%= state.name %> income tax forms, instructions, and filing guidance is the <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a>.</p>
    </div>

    <% } else { %>

    <div class="faq-item">
      <h3>Does <%= state.name %> have a state income tax?</h3>
      <p>No. <%= state.name %> does not impose a broad-based state income tax on wages, salaries, or most personal income. <%= state.noTaxNote %></p>
    </div>

    <div class="faq-item">
      <h3>Do I still owe federal income tax as a <%= state.name %> resident?</h3>
      <p>Yes. Federal income tax applies to all U.S. residents regardless of state. <%= state.name %> residents pay the same federal tax brackets as residents of any other state. Only your state income tax liability is $0.</p>
    </div>

    <div class="faq-item">
      <h3>What taxes do <%= state.name %> residents pay instead of income tax?</h3>
      <p><%= state.overview.substring(0, 300) %>... See the full overview above for details.</p>
    </div>

    <div class="faq-item">
      <h3>Do I need to file a <%= state.name %> state tax return?</h3>
      <p><%= state.name %> does not have a personal income tax return requirement for most residents. However, you must still file a federal return with the IRS. Check the <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a> for any state-specific filing obligations that may apply.</p>
    </div>

    <% } %>

  </section>

  <!-- Related Links -->
  <section class="related-calculators">
    <h2>Related Tax Resources</h2>
    <div class="related-grid">
      <a href="/income-tax-calculator" class="related-card"><strong>Federal Income Tax Calculator</strong> Estimate your total federal tax bill</a>
      <a href="/tax-refund-calculator" class="related-card"><strong>Tax Refund Calculator</strong> Will you get a refund or owe?</a>
      <a href="/tax-brackets-2025" class="related-card"><strong>2025 Federal Tax Brackets</strong> Full federal bracket tables</a>
      <a href="/standard-deduction-2025" class="related-card"><strong>Standard Deduction 2025</strong> Deduction amounts by filing status</a>
      <a href="/states" class="related-card"><strong>All State Calculators</strong> Compare all 50 states + D.C.</a>
      <a href="/payroll-tax-calculator" class="related-card"><strong>Payroll Tax Calculator</strong> Estimate take-home pay</a>
    </div>
  </section>

  <p class="disclaimer"><strong>Disclaimer:</strong> This calculator provides estimates for educational purposes only. State tax results are approximations based on published bracket data and do not account for all deductions, credits, exemptions, local taxes, or individual tax situations. It is not tax, legal, or financial advice. Always consult the <a href="<%= state.revenueUrl.url %>" target="_blank" rel="noopener noreferrer"><%= state.revenueUrl.label %></a> or a qualified tax professional for guidance specific to your situation.</p>

</main>

<%- include('partials/footer') %>
