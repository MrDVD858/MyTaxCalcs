<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <style>
    .blog-hub-wrap{max-width:1080px;margin:0 auto;padding:0 28px 56px}
    @media(max-width:700px){.blog-hub-wrap{padding:0 18px 48px}}
    .ad-zone{text-align:center;margin:10px 0;min-height:0}
    .ad-zone-label{font-size:.63rem;color:#b0bbc9;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
  </style>
  <script>
    (function() {
      function collapseEmptyAdZones() {
        document.querySelectorAll('.ad-zone').forEach(function(zone) {
          var ins = zone.querySelector('ins.adsbygoogle');
          if (!ins) return;
          var status = ins.getAttribute('data-ad-status');
          var h = ins.offsetHeight || parseInt((ins.style.height || '0'), 10);
          if (status === 'unfilled' || h === 0) {
            zone.style.cssText = 'margin:0!important;padding:0!important;min-height:0!important;line-height:0!important;overflow:hidden';
          }
        });
      }
      window.addEventListener('load', function() { setTimeout(collapseEmptyAdZones, 1000); setTimeout(collapseEmptyAdZones, 2500); });
      if (window.MutationObserver) {
        var mo = new MutationObserver(function(muts) {
          muts.forEach(function(m) { if (m.type === 'attributes' && m.attributeName === 'data-ad-status') collapseEmptyAdZones(); });
        });
        document.addEventListener('DOMContentLoaded', function() {
          document.querySelectorAll('ins.adsbygoogle').forEach(function(ins) { mo.observe(ins, { attributes: true }); });
        });
      }
    })();
  </script>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="nav-mobile-drawer" id="nav-mobile-drawer" role="navigation" aria-label="Mobile navigation">
      <div class="nav-mobile-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-mobile-cta" href="/calculators">All Calculators</a>
    </div>
  </header>

  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-glow"></div>
    <div class="page-hero-inner">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="hbc-sep">&#8250;</span>
        <span class="hbc-current">Tax Blog</span>
      </nav>
      <div class="page-hero-eyebrow">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        IRS Insights &amp; Tax Guides
      </div>
      <h1>MyTaxCalcs Tax Blog</h1>
      <p>Plain-English guides, IRS updates, and tax law changes to help you plan and file with confidence.</p>
      <div class="blog-hero-stats">
        <div class="blog-hero-stat"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg><strong>58+</strong> articles</div>
        <div class="blog-hero-sep"></div>
        <div class="blog-hero-stat"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Updated for <strong>2025 &amp; 2026</strong></div>
        <div class="blog-hero-sep"></div>
        <div class="blog-hero-stat"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>IRS-sourced data</div>
      </div>
    </div>
  </section>

  <div class="page-with-sidebar">
  <main>
    <div class="blog-hub-wrap">

      <div class="ad-zone" style="margin:24px 0 20px">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <%
        var activePosts = [];
        if (typeof posts !== 'undefined' && posts) { activePosts = posts; }
        else if (typeof blogposts !== 'undefined' && blogposts) { activePosts = blogposts; }
      %>

      <% if (activePosts.length > 0) { %>

        <!-- FEATURED: top 2 posts, big editorial cards -->
        <div class="blog-cat-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Latest &amp; Featured
        </div>
        <div class="blog-featured-row" style="margin-bottom:20px">
          <% var feat = activePosts[0]; %>
          <a href="/blog/<%= feat.slug %>" class="blog-card-featured">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px">
              <span class="bcp-cat"><%= feat.category %></span>
              <span class="bcp-date"><%= feat.date %></span>
            </div>
            <h2><%= feat.title %></h2>
            <p><%= feat.excerpt %></p>
            <div class="bcp-footer" style="margin-top:auto">
              <span class="bcp-author">By <%= feat.author %></span>
              <span class="bcp-arrow">Read Article &#8250;</span>
            </div>
          </a>
          <div style="display:flex;flex-direction:column;gap:12px">
            <% activePosts.slice(1,3).forEach(function(post) { %>
            <a href="/blog/<%= post.slug %>" class="blog-card-secondary">
              <div style="display:flex;align-items:center;gap:7px;margin-bottom:4px">
                <span class="bcp-cat"><%= post.category %></span>
                <span class="bcp-date"><%= post.date %></span>
              </div>
              <h2><%= post.title %></h2>
              <p><%= post.excerpt.substring(0,100) %><%= post.excerpt.length > 100 ? '...' : '' %></p>
              <span class="bcp-arrow" style="font-size:.8rem;font-weight:700;color:#16a34a;margin-top:auto">Read &#8250;</span>
            </a>
            <% }) %>
          </div>
        </div>

        <!-- RECENT: posts 3-11 in compact grid -->
        <% if (activePosts.length > 3) { %>
        <div class="blog-cat-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Recent Articles
        </div>
        <div class="blog-standard-grid">
          <% activePosts.slice(3, 12).forEach(function(post) { %>
          <a href="/blog/<%= post.slug %>" class="blog-card-compact">
            <span class="bcp-cat"><%= post.category %></span>
            <h2><%= post.title %></h2>
            <span class="bcp-date"><%= post.date %></span>
          </a>
          <% }) %>
        </div>
        <% } %>

        <!-- AD break -->
        <div class="ad-zone" style="margin:8px 0">
          <div class="ad-zone-label">Advertisement</div>
          <ins class="adsbygoogle" style="display:block"
            data-ad-client="ca-pub-5193834725888549"
            data-ad-slot="4212978293"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <!-- MORE: posts 12+ -->
        <% if (activePosts.length > 12) { %>
        <div class="blog-cat-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          More Articles
        </div>
        <div class="blog-standard-grid">
          <% activePosts.slice(12).forEach(function(post) { %>
          <a href="/blog/<%= post.slug %>" class="blog-card-compact">
            <span class="bcp-cat"><%= post.category %></span>
            <h2><%= post.title %></h2>
            <span class="bcp-date"><%= post.date %></span>
          </a>
          <% }) %>
        </div>
        <% } %>

      <% } else { %>
        <p>No blog posts found.</p>
      <% } %>

      <!-- CTA TO CALCULATORS -->
      <div class="blog-cta-strip">
        <div>
          <h3>Ready to estimate your taxes?</h3>
          <p>Six free calculators &mdash; income tax, refund, self-employment, capital gains, sales tax, and payroll.</p>
        </div>
        <a href="/calculators" class="blog-cta-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
          Open a Calculator
        </a>
      </div>

    </div>
  </main>
  <aside class="sidebar-ad-col" aria-label="Advertisement" aria-hidden="true">
    <div class="sidebar-ad-inner">
      <p class="sidebar-ad-label">Ad</p>
      <ins class="adsbygoogle"
           style="display:block;width:160px;min-height:600px"
           data-ad-client="ca-pub-5193834725888549"
           data-ad-slot="4041103773"
           data-ad-format="auto"
           data-full-width-responsive="false"></ins>
      <script>
        (function(){
          var ins=document.currentScript.previousElementSibling;
          var io=new IntersectionObserver(function(entries,observer){
            if(entries[0].isIntersecting){(adsbygoogle=window.adsbygoogle||[]).push({});observer.disconnect();}
          },{rootMargin:'200px'});
          io.observe(ins);
        })();
      </script>
    </div>
  </aside>
</div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Tax Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div style="margin-top:24px;border-top:1px solid rgba(255,255,255,0.08);padding-top:24px">
        <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,0.3);margin-bottom:14px">Our Calculator Network</p>
        <div style="display:flex;gap:24px;flex-wrap:wrap">
          <a href="https://myinsurancecalcs.com" target="_blank" rel="noopener noreferrer" style="font-size:.85rem;color:#6b84a8;font-weight:500" onmouseover="this.style.color='#22c55e'" onmouseout="this.style.color='#6b84a8'">MyInsuranceCalcs.com &#8599;</a>
          <a href="https://myloancalcs.com" target="_blank" rel="noopener noreferrer" style="font-size:.85rem;color:#6b84a8;font-weight:500" onmouseover="this.style.color='#22c55e'" onmouseout="this.style.color='#6b84a8'">MyLoanCalcs.com &#8599;</a>
          <a href="https://mypctcalculator.com" target="_blank" rel="noopener noreferrer" style="font-size:.85rem;color:#6b84a8;font-weight:500" onmouseover="this.style.color='#22c55e'" onmouseout="this.style.color='#6b84a8'">MyPctCalculator.com &#8599;</a>
        </div>
      </div>
      <div class="footer-bottom"><p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>

  <script>
    (function() {
      var btn = document.querySelector('.nav-hamburger');
      var drawer = document.getElementById('nav-mobile-drawer');
      if (!btn || !drawer) return;
      btn.addEventListener('click', function() {
        var open = drawer.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
      document.addEventListener('click', function(e) {
        if (!btn.contains(e.target) && !drawer.contains(e.target)) {
          drawer.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Open menu');
        }
      });
    })();
  </script>
</body>
</html>
