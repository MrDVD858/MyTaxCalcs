<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <style>
    .breadcrumb{max-width:1000px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db;font-size:.75rem}
    .blog-page{max-width:1000px;margin:0 auto;padding:0 24px 60px}
    .blog-header{padding:28px 0 32px;border-bottom:1px solid #e5e7eb;margin-bottom:32px}
    .page-eyebrow{display:inline-flex;align-items:center;gap:6px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:4px 12px;margin-bottom:12px}
    .blog-header h1{font-size:2.2rem;font-weight:800;line-height:1.2;margin:0 0 10px;color:#111827}
    .blog-header p{font-size:1.05rem;color:#6b7280;margin:0;max-width:640px;line-height:1.5}
    .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:48px}
    @media(max-width:850px){.blog-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:550px){.blog-grid{grid-template-columns:1fr}}
    .blog-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;text-decoration:none;color:inherit;transition:all .2s;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(0,0,0,.02)}
    .blog-card:hover{border-color:#16a34a;box-shadow:0 10px 25px rgba(22,163,74,.05);transform:translateY(-2px)}
    .card-meta{display:flex;align-items:center;gap:8px;margin-bottom:12px;font-size:.8rem;color:#6b7280}
    .card-category{background:#f0fdf4;color:#16a34a;font-weight:600;padding:2px 8px;border-radius:4px}
    .blog-card h2{font-size:1.15rem;font-weight:700;color:#111827;margin:0 0 10px;line-height:1.4}
    .blog-card p{font-size:.88rem;color:#6b7280;line-height:1.5;margin:0 0 16px;flex-grow:1}
    .card-author-line{font-size:.8rem;color:#9ca3af;border-top:1px solid #f3f4f6;padding-top:12px;margin-top:auto}
    .ad-zone{text-align:center;margin:28px 0;min-height:90px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
  </style>
</head>
<body>

    <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="nav-mobile-drawer" id="nav-mobile-drawer" role="navigation" aria-label="Mobile navigation">
      <div class="nav-mobile-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-mobile-cta" href="/calculators">All Calculators</a>
    </div>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <span>Tax Blog</span>
  </nav>

  <div class="page-with-sidebar">
  <main>
    <div class="blog-page">

      <div class="blog-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 02 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          IRS Insights
        </div>
        <h1>MyTaxCalcs Editorial Blog</h1>
        <p>Expert legal interpretations, policy reviews, inflation adjustments, and clear tracking of official IRS releases.</p>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="blog-grid">
        <% 
          // Fault-tolerant array check fallback
          let activePosts = [];
          if (typeof posts !== 'undefined' && posts) { activePosts = posts; }
          else if (typeof blogposts !== 'undefined' && blogposts) { activePosts = blogposts; }
        %>
        
        <% if (activePosts.length > 0) { %>
          <% activePosts.forEach(function(post) { %>
            <a href="/blog/<%= post.slug %>" class="blog-card">
              <div class="card-meta">
                <span class="card-category"><%= post.category %></span>
                <span>•</span>
                <span><%= post.date %></span>
              </div>
              <h2><%= post.title %></h2>
              <p><%= post.excerpt %></p>
              <div class="card-author-line">By <%= post.author %></div>
            </a>
          <% }) %>
        <% } else { %>
          <p>No blog posts found.</p>
        <% } %>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

    </div>
  </main>
  <aside class="sidebar-ad-col" aria-label="Advertisement" aria-hidden="true">
    <div class="sidebar-ad-inner">
      <p class="sidebar-ad-label">Ad</p>
      <ins class="adsbygoogle"
           style="display:block;width:160px;min-height:600px"
           data-ad-client="ca-pub-5193834725888549"
           data-ad-slot="4041103773"
           data-ad-format="auto"
           data-full-width-responsive="false"></ins>
      <script>
        (function(){
          var ins=document.currentScript.previousElementSibling;
          var io=new IntersectionObserver(function(entries,observer){
            if(entries[0].isIntersecting){
              (adsbygoogle=window.adsbygoogle||[]).push({});
              observer.disconnect();
            }
          },{rootMargin:'200px'});
          io.observe(ins);
        })();
      </script>
    </div>
  </aside>
</div>


  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Tax Blog</a>
          <a href="/blog">Blog</a>
<a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom"><p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>


  <script>
    (function() {
      var btn = document.querySelector('.nav-hamburger');
      var drawer = document.getElementById('nav-mobile-drawer');
      if (!btn || !drawer) return;
      btn.addEventListener('click', function() {
        var open = drawer.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
      document.addEventListener('click', function(e) {
        if (!btn.contains(e.target) && !drawer.contains(e.target)) {
          drawer.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Open menu');
        }
      });
    })();
  </script>
</body>
</html>