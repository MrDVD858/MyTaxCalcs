<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <style>
    .breadcrumb{max-width:1100px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db}
    .blog-page{max-width:1100px;margin:0 auto;padding:0 24px 60px}
    .blog-header{padding:36px 0 32px}
    .page-eyebrow{display:inline-flex;align-items:center;gap:6px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:4px 12px;margin-bottom:12px}
    .blog-header h1{font-size:2rem;font-weight:800;line-height:1.2;margin:0 0 10px;color:#111827}
    .blog-header p{font-size:1rem;color:#6b7280;margin:0;max-width:620px;line-height:1.6}
    .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
    @media(max-width:900px){.blog-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:560px){.blog-grid{grid-template-columns:1fr}}
    .blog-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:22px;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:10px;transition:border-color .15s,box-shadow .15s,transform .15s}
    .blog-card:hover{border-color:#16a34a;box-shadow:0 4px 16px rgba(22,163,74,.1);transform:translateY(-2px)}
    .blog-card-category{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:3px 10px;display:inline-block;width:fit-content}
    .blog-card-title{font-size:1rem;font-weight:700;color:#111827;line-height:1.4;margin:0}
    .blog-card-excerpt{font-size:.875rem;color:#6b7280;line-height:1.6;margin:0;flex:1}
    .blog-card-meta{font-size:.78rem;color:#9ca3af;display:flex;align-items:center;gap:8px;margin-top:4px}
    .blog-card-meta-dot{width:3px;height:3px;border-radius:50%;background:#d1d5db}
    .blog-card-read{font-size:.82rem;font-weight:600;color:#16a34a;display:flex;align-items:center;gap:4px;margin-top:2px}
    .irs-notice{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:18px 22px;margin-bottom:36px;display:flex;gap:12px;align-items:flex-start}
    .irs-notice svg{min-width:20px;color:#16a34a;margin-top:1px}
    .irs-notice p{font-size:.875rem;color:#14532d;margin:0;line-height:1.6}
    .irs-notice strong{color:#14532d}
    .ad-zone{text-align:center;margin:0 auto 40px;max-width:1100px;min-height:90px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
  </style>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog" aria-current="page">Blog</a>
        <a href="/about">About</a>
      </div>
      <a class="nav-cta" href="/income-tax-calculator">Get Started</a>
    </nav>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <span>Tax Blog</span>
  </nav>

  <main>
    <div class="blog-page">

      <div class="blog-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Tax News & Guides
        </div>
        <h1>Tax Blog</h1>
        <p>IRS announcements, tax law changes, and plain-language guides to help you understand your federal and state tax obligations.</p>
      </div>

      <div class="irs-notice">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p><strong>Sourced from official IRS publications.</strong> All figures and tax law changes referenced in our posts are drawn directly from IRS revenue procedures, notices, and press releases. We cite the source in every article. This content is educational only — not tax, legal, or financial advice.</p>
      </div>

      <div class="blog-grid">
        <% posts.forEach(function(post) { %>
          <a class="blog-card" href="/blog/<%= post.slug %>">
            <span class="blog-card-category"><%= post.category %></span>
            <p class="blog-card-title"><%= post.title %></p>
            <p class="blog-card-excerpt"><%= post.excerpt %></p>
            <div class="blog-card-meta">
              <span><%= post.date %></span>
              <span class="blog-card-meta-dot"></span>
              <span><%= post.author %></span>
            </div>
            <span class="blog-card-read">Read article →</span>
          </a>
        <% }) %>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>
            MyTaxCalcs
          </a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Tax Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p>
      </div>
    </div>
  </footer>

</body>
</html>
