  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [      {
        "@type": "Question",
        "name": "How do I set up an IRS payment plan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can apply online at IRS.gov/OPA (Online Payment Agreement) if you owe $50,000 or less in combined tax, penalties, and interest and have filed all required returns. The online system is available 24/7 and provides immediate approval for most applicants. You can also apply by filing Form 9465 by mail or by calling the IRS directly."
        }
      },
      {
        "@type": "Question",
        "name": "How much does an IRS payment plan cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The IRS charges a setup fee for installment agreements. For online applications, the fee is $31 for direct debit agreements and $130 for non-direct-debit agreements. Low-income taxpayers may qualify for a reduced fee of $43 or a fee waiver. Interest accrues at the federal short-term rate plus 3% (currently around 7-8% annually), and the failure-to-pay penalty of 0.5% per month is reduced to 0.25% while a payment plan is active."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I miss an IRS payment plan payment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Missing a payment puts your installment agreement at risk of default. The IRS will send a notice giving you 30 days to cure the default by making the missed payment. If the agreement defaults, the IRS can resume enforcement collection actions including filing a tax lien or issuing a levy. You can reinstate a defaulted agreement once, but repeat defaults may result in the IRS refusing to set up a new plan."
        }
      }]
  }
