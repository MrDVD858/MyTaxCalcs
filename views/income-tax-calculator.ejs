  <meta name="description" content="Free federal income tax calculator for 2025. Estimate taxable income, federal tax owed, refund or amount owed, effective tax rate, and marginal tax rate.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta property="og:title" content="Free Income Tax Calculator 2025 | MyTaxCalcs">
  <meta property="og:description" content="Estimate your 2025 federal income tax, taxable income, refund, effective tax rate, and marginal tax rate for free.">
