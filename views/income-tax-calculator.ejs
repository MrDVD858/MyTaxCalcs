<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %> | MyTaxCalcs</title>
  <meta name="description" content="Use our free income tax calculator to estimate federal taxable income, tax owed, refund, effective tax rate, and marginal tax rate.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
</head>
<body>

  <!-- ── HEADER ── -->
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/california-income-tax-calculator">States</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
    </nav>
  </header>

  <!-- ── PAGE HERO ── -->
  <section class="calc-hero">
    <div class="calc-hero-inner">
      <div class="section-label">Federal Tax Estimator</div>
      <h1>Free Income Tax Calculator</h1>
      <p>Estimate your federal income tax, taxable income, refund, or amount owed for 2024.</p>
    </div>
  </section>

  <!-- ── CALCULATOR ── -->
  <main class="calc-main">
    <div class="calc-layout">

      <!-- FORM -->
      <section class="calc-form-card">
        <div class="calc-form-header">
          <div class="calc-form-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h4M7 12h8"/></svg>
          </div>
          <h2>Your Tax Information</h2>
        </div>

        <form method="POST" action="/income-tax-calculator" class="calc-form">
          <div class="form-group">
            <label for="grossIncome">Gross Annual Income</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input type="number" id="grossIncome" name="grossIncome" value="<%= form.grossIncome || '' %>" placeholder="85,000" required>
            </div>
          </div>

          <div class="form-group">
            <label for="filingStatus">Filing Status</label>
            <select id="filingStatus" name="filingStatus">
              <option value="single" <%= form.filingStatus === 'single' ? 'selected' : '' %>>Single</option>
              <option value="marriedJoint" <%= form.filingStatus === 'marriedJoint' ? 'selected' : '' %>>Married Filing Jointly</option>
              <option value="marriedSeparate" <%= form.filingStatus === 'marriedSeparate' ? 'selected' : '' %>>Married Filing Separately</option>
              <option value="headHousehold" <%= form.filingStatus === 'headHousehold' ? 'selected' : '' %>>Head of Household</option>
            </select>
          </div>

          <div class="form-group">
            <label for="deductionType">Deduction Type</label>
            <select id="deductionType" name="deductionType">
              <option value="standard" <%= form.deductionType === 'standard' ? 'selected' : '' %>>Standard Deduction</option>
              <option value="itemized" <%= form.deductionType === 'itemized' ? 'selected' : '' %>>Itemized Deduction</option>
            </select>
          </div>

          <div class="form-group">
            <label for="itemizedDeduction">Itemized Deduction Amount</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input type="number" id="itemizedDeduction" name="itemizedDeduction" value="<%= form.itemizedDeduction || '' %>" placeholder="0">
            </div>
          </div>

          <div class="form-group">
            <label for="federalWithheld">Federal Tax Withheld</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input type="number" id="federalWithheld" name="federalWithheld" value="<%= form.federalWithheld || '' %>" placeholder="12,000">
            </div>
          </div>

          <div class="form-group">
            <label for="taxCredits">Tax Credits</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input type="number" id="taxCredits" name="taxCredits" value="<%= form.taxCredits || '' %>" placeholder="0">
            </div>
          </div>

          <button type="submit" class="calc-submit-btn">
            Calculate Tax Estimate
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </section>

      <!-- RESULTS -->
      <section class="calc-results-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#f0fdf4; color:#16a34a;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h2>Estimated Results</h2>
        </div>

        <% if (!result) { %>
          <div class="results-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <p>Enter your information and click <strong>Calculate</strong> to see your tax estimate.</p>
          </div>
        <% } else { %>
          <div class="results-grid">
            <div class="result-row">
              <span>Gross Income</span>
              <strong>$<%= Math.round(result.grossIncome).toLocaleString() %></strong>
            </div>
            <div class="result-row">
              <span>Deduction</span>
              <strong>$<%= Math.round(result.deduction).toLocaleString() %></strong>
            </div>
            <div class="result-row">
              <span>Taxable Income</span>
              <strong>$<%= Math.round(result.taxableIncome).toLocaleString() %></strong>
            </div>
            <div class="result-row">
              <span>Federal Tax After Credits</span>
              <strong>$<%= Math.round(result.federalTaxAfterCredits).toLocaleString() %></strong>
            </div>
            <div class="result-row">
              <span>Federal Tax Withheld</span>
              <strong>$<%= Math.round(result.federalWithheld).toLocaleString() %></strong>
            </div>

            <div class="result-row result-highlight <%= result.refundOrOwed >= 0 ? 'refund' : 'owed' %>">
              <% if (result.refundOrOwed >= 0) { %>
                <span>Estimated Refund</span>
                <strong>$<%= Math.round(result.refundOrOwed).toLocaleString() %></strong>
              <% } else { %>
                <span>Estimated Amount Owed</span>
                <strong>$<%= Math.abs(Math.round(result.refundOrOwed)).toLocaleString() %></strong>
              <% } %>
            </div>

            <div class="result-row">
              <span>Effective Tax Rate</span>
              <strong><%= (result.effectiveTaxRate * 100).toFixed(1) %>%</strong>
            </div>
            <div class="result-row">
              <span>Marginal Tax Rate</span>
              <strong><%= (result.marginalRate * 100).toFixed(1) %>%</strong>
            </div>
          </div>
        <% } %>

        <div class="results-disclaimer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Estimate only. Not tax, legal, accounting, or financial advice.
        </div>
      </section>

    </div>

    <!-- ── SEO CONTENT ── -->
    <div class="calc-content-wrapper">
      <section class="content seo-content">
        <p class="eyebrow dark">Income Tax Calculator Guide</p>
        <h2>How this income tax calculator works</h2>
        <p>This income tax calculator estimates federal income tax by using your gross income, filing status, deduction choice, federal withholding, and tax credits. It then estimates taxable income, federal tax after credits, effective tax rate, marginal tax rate, and whether you may receive a refund or owe additional federal tax.</p>

        <div class="seo-grid">
          <div class="seo-mini-card">
            <h3>What it includes</h3>
            <p>Gross income, standard or itemized deductions, filing status, federal withholding, and tax credits entered by the user.</p>
          </div>
          <div class="seo-mini-card">
            <h3>What it estimates</h3>
            <p>Taxable income, estimated federal tax, refund or amount owed, effective tax rate, and marginal tax rate.</p>
          </div>
          <div class="seo-mini-card">
            <h3>What it excludes</h3>
            <p>Every tax credit, phaseout, local tax, alternative minimum tax, Medicare surtax, or special tax situation.</p>
          </div>
        </div>

        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3>Is this income tax calculator exact?</h3>
            <p>No. This calculator provides an estimate only. Your actual tax result may differ based on credits, deductions, dependents, retirement contributions, business income, state taxes, and other tax rules.</p>
          </div>
          <div class="faq-item">
            <h3>What is taxable income?</h3>
            <p>Taxable income is the amount of income left after subtracting deductions from gross income. This calculator estimates taxable income based on the deduction option you select.</p>
          </div>
          <div class="faq-item">
            <h3>What is the difference between marginal and effective tax rate?</h3>
            <p>A marginal tax rate is the rate applied to the last portion of taxable income. An effective tax rate is the estimated total federal tax divided by gross income.</p>
          </div>
          <div class="faq-item">
            <h3>Does this calculator include state income tax?</h3>
            <p>This page focuses on federal income tax. Use the state calculator pages for state-specific tax information and estimates.</p>
          </div>
          <div class="faq-item">
            <h3>Should I use standard or itemized deductions?</h3>
            <p>Many taxpayers use the standard deduction, but some may itemize if their eligible deductions are higher. This calculator lets you compare either approach.</p>
          </div>
        </div>
        <p class="last-updated">Last updated: April 2026</p>
      </section>

      <section class="content related-calculators">
        <p class="eyebrow dark">Related Calculators</p>
        <h2>More tax calculators</h2>
        <div class="related-grid">
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
          <a href="/calculators">All Calculators</a>
        </div>
      </section>
    </div>

  </main>

  <!-- ── FOOTER ── -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <span class="logo-mark">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
                <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
                <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
                <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
              </svg>
            </span>
            MyTaxCalcs
          </a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
