              <tr><td class="rate rate-35">35%</td><td class="range">$250,525 to $626,350</td><td class="on">$57,231.50 + 35% of amount over $250,525</td></tr>
              <tr><td class="rate rate-37">37%</td><td class="range">Over $626,350</td><td class="on">$188,769.75 + 37% of amount over $626,350</td></tr>
            </tbody>
          </table>
