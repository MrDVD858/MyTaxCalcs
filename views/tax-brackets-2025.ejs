            <tbody>
              <tr><td class="rate rate-10">10%</td><td class="range">$0 to $11,925</td><td class="on">10% of taxable income</td></tr>
              <tr><td class="rate rate-12">12%</td><td class="range">$11,925 to $48,475</td><td class="on">$1,192.50 + 12% of amount over $11,925</td></tr>
              <tr><td class="rate rate-22">22%</td><td class="range">$48,475 to $103,350</td><td class="on">$5,578.50 + 22% of amount over $48,475</td></tr>
              <tr><td class="rate rate-24">24%</td><td class="range">$103,350 to $197,300</td><td class="on">$17,651.50 + 24% of amount over $103,350</td></tr>
              <tr><td class="rate rate-32">32%</td><td class="range">$197,300 to $250,525</td><td class="on">$40,199.50 + 32% of amount over $197,300</td></tr>
              <tr><td class="rate rate-35">35%</td><td class="range">$250,525 to $375,800</td><td class="on">$57,231.50 + 35% of amount over $250,525</td></tr>
