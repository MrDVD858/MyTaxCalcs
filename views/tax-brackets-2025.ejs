  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the 2025 federal income tax brackets?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 2025 federal tax brackets for single filers are: 10% on income up to $11,925; 12% on $11,925 to $48,475; 22% on $48,475 to $103,350; 24% on $103,350 to $197,300; 32% on $197,300 to $250,525; 35% on $250,525 to $626,350; and 37% on income above $626,350."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between marginal and effective tax rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your marginal tax rate is the rate applied to the last dollar of your taxable income. Your effective tax rate is your total federal tax divided by your gross income. Because the US uses a progressive system, your effective rate is always lower than your marginal rate."
        }
      },
      {
        "@type": "Question",
        "name": "Did the tax brackets change for 2025?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tax rates themselves (10%, 12%, 22%, 24%, 32%, 35%, 37%) did not change. However, the income thresholds for each bracket were adjusted upward for inflation, meaning more of your income falls into lower brackets compared to 2024."
        }
      }
    ]
  }
