              <select id="assetType" name="assetType">
                <option value="stocks" <%= (!form.assetType || form.assetType === 'stocks') ? 'selected' : '' %>>Stocks / ETFs / Mutual Funds</option>
                <option value="crypto" <%= form.assetType === 'crypto' ? 'selected' : '' %>>Cryptocurrency</option>
                <option value="realestate" <%= form.assetType === 'realestate' ? 'selected' : '' %>>Real Estate (Investment Property)</option>
                <option value="collectibles" <%= form.assetType === 'collectibles' ? 'selected' : '' %>>Collectibles (Art, Coins, etc.)</option>
