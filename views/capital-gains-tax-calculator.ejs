  <section class="calc-hero">
    <div class="calc-hero-inner">
      <div class="section-label">Stocks, Crypto & Real Estate</div>
      <h1>Capital Gains Tax Calculator</h1>
      <p>Estimate federal tax on the profit from selling stocks, crypto, real estate, or other assets.</p>
    </div>
  </section>

  <main class="calc-main">
    <div class="calc-layout">
      <section class="calc-form-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#fef3c7; color:#d97706;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <h2>Asset Sale Information</h2>
        </div>
        <form method="POST" action="/capital-gains-tax-calculator" class="calc-form">
          <div class="form-group">
            <label>Filing Status</label>
            <select name="filingStatus">
              <option value="single" <%= form.filingStatus === "single" ? "selected" : "" %>>Single</option>
              <option value="marriedJoint" <%= form.filingStatus === "marriedJoint" ? "selected" : "" %>>Married Filing Jointly</option>
              <option value="marriedSeparate" <%= form.filingStatus === "marriedSeparate" ? "selected" : "" %>>Married Filing Separately</option>
              <option value="headHousehold" <%= form.filingStatus === "headHousehold" ? "selected" : "" %>>Head of Household</option>
            </select>
          </div>
          <div class="form-group">
            <label>Holding Period</label>
            <select name="holdingPeriod">
              <option value="long" <%= form.holdingPeriod === "long" ? "selected" : "" %>>Long-term (more than 1 year)</option>
              <option value="short" <%= form.holdingPeriod === "short" ? "selected" : "" %>>Short-term (1 year or less)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Sale Price</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="salePrice" value="<%= form.salePrice || '' %>" placeholder="150,000" required></div>
          </div>
          <div class="form-group">
            <label>Purchase Price / Cost Basis</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="purchasePrice" value="<%= form.purchasePrice || '' %>" placeholder="80,000" required></div>
          </div>
          <div class="form-group">
            <label>Selling Costs</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="sellingCosts" value="<%= form.sellingCosts || '' %>" placeholder="5,000"></div>
          </div>
          <div class="form-group">
            <label>Capital Improvements</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="improvements" value="<%= form.improvements || '' %>" placeholder="0"></div>
          </div>
          <div class="form-group">
            <label>Capital Losses to Offset Gains</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="capitalLosses" value="<%= form.capitalLosses || '' %>" placeholder="0"></div>
          </div>
          <div class="form-group">
            <label>Other Taxable Income</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="otherTaxableIncome" value="<%= form.otherTaxableIncome || '' %>" placeholder="85,000"></div>
          </div>
          <button type="submit" class="calc-submit-btn">Calculate Capital Gains Tax <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        </form>
      </section>

      <section class="calc-results-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#fef3c7; color:#d97706;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h2>Estimated Results</h2>
        </div>
        <% if (!result) { %>
          <div class="results-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
            <p>Enter sale, basis, income, and holding period information to estimate capital gains tax.</p>
          </div>
        <% } else { %>
          <div class="results-grid">
            <div class="result-row"><span>Tax Year</span><strong><%= result.taxYear %></strong></div>
            <div class="result-row"><span>Sale Price</span><strong>$<%= Math.round(result.salePrice).toLocaleString() %></strong></div>
            <div class="result-row"><span>Adjusted Basis</span><strong>$<%= Math.round(result.adjustedBasis).toLocaleString() %></strong></div>
            <div class="result-row"><span>Gross Capital Gain</span><strong>$<%= Math.round(result.grossGain).toLocaleString() %></strong></div>
            <div class="result-row"><span>Capital Losses</span><strong>$<%= Math.round(result.capitalLosses).toLocaleString() %></strong></div>
            <div class="result-row"><span>Net Taxable Gain</span><strong>$<%= Math.round(result.netGain).toLocaleString() %></strong></div>
            <div class="result-row"><span>Est. Capital Gains Tax</span><strong>$<%= Math.round(result.estimatedCapitalGainsTax).toLocaleString() %></strong></div>
            <div class="result-row"><span>Estimated NIIT</span><strong>$<%= Math.round(result.estimatedNIIT).toLocaleString() %></strong></div>
            <div class="result-row result-highlight owed">
              <span>Total Estimated Tax</span>
              <strong>$<%= Math.round(result.totalEstimatedTax).toLocaleString() %></strong>
            </div>
            <div class="result-row"><span>Effective Rate on Gain</span><strong><%= (result.effectiveCapitalGainsRate * 100).toFixed(1) %>%</strong></div>
          </div>
          <% if (result.taxMethod) { %><p style="font-size:0.82rem;color:var(--muted);margin-top:12px;padding:0 4px;"><%= result.taxMethod %></p><% } %>
        <% } %>
        <div class="results-disclaimer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Estimate only. Not tax, legal, accounting, investment, or financial advice.
        </div>
      </section>
    </div>

    <div class="calc-content-wrapper">
      <section class="content seo-content">
        <p class="eyebrow dark">Capital Gains Tax Guide</p>
        <h2>How this capital gains tax calculator works</h2>
        <p>This calculator estimates the federal tax that may apply when you sell an asset for more than your adjusted basis. It can be used for planning around stocks, crypto, real estate, business property, or other assets, but it does not replace official tax software or a tax professional.</p>
        <div class="seo-grid">
          <div class="seo-mini-card"><h3>Cost basis</h3><p>Cost basis generally starts with what you paid for the asset. This calculator also lets you add selling costs and capital improvements to estimate adjusted basis.</p></div>
          <div class="seo-mini-card"><h3>Short-term gains</h3><p>Short-term gains are generally gains on assets held for one year or less and are estimated using ordinary federal income tax brackets.</p></div>
          <div class="seo-mini-card"><h3>Long-term gains</h3><p>Long-term gains are generally gains on assets held for more than one year and may qualify for lower federal capital gains tax rates.</p></div>
        </div>
        <h2>Capital gains tax FAQ</h2>
        <div class="faq-list">
          <div class="faq-item"><h3>What is capital gains tax?</h3><p>Capital gains tax is tax on profit from selling an asset for more than its adjusted basis. The tax treatment can depend on the asset type, holding period, filing status, income, and losses.</p></div>
          <div class="faq-item"><h3>What is the difference between short-term and long-term capital gains?</h3><p>Short-term gains generally apply to assets held for one year or less. Long-term gains generally apply to assets held for more than one year and may qualify for lower federal tax rates.</p></div>
          <div class="faq-item"><h3>Does this calculator include state capital gains tax?</h3><p>No. This calculator focuses on federal estimates. Some states tax capital gains as ordinary income, while others may have different rules or no state income tax.</p></div>
          <div class="faq-item"><h3>What is Net Investment Income Tax?</h3><p>Net Investment Income Tax is an additional federal tax that may apply to certain investment income when income is above specific thresholds. This calculator includes a simplified NIIT estimate.</p></div>
          <div class="faq-item"><h3>Can I use this calculator for tax filing?</h3><p>No. This calculator is for educational planning only. For filing, use official tax forms, tax software, or a qualified tax professional.</p></div>
        </div>
        <p class="last-updated">Last updated: April 2026</p>
      </section>
      <section class="content related-calculators">
        <p class="eyebrow dark">Related Calculators</p>
        <h2>More tax calculators</h2>
        <div class="related-grid">
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
          <a href="/calculators">All Calculators</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
