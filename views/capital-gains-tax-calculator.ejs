    "url": "https://mytaxcalcs.com/capital-gains-tax-calculator",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript",
    "dateModified": "2025-11-01",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "provider": {
      "@type": "Organization",
      "name": "MyTaxCalcs",
      "url": "https://mytaxcalcs.com"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between short-term and long-term capital gains?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Short-term gains apply to assets held one year or less and are taxed as ordinary income at your regular tax rate, which can be as high as 37%. Long-term gains apply to assets held more than one year and are taxed at preferential rates of 0%, 15%, or 20% depending on your income."
      }
    },
    {
      "@type": "Question",
      "name": "Can capital losses offset capital gains?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Capital losses offset gains dollar-for-dollar. If your net losses exceed your gains, you can deduct up to $3,000 against ordinary income per year. Additional losses can be carried forward to future tax years."
      }
    },
    {
      "@type": "Question",
      "name": "How is cryptocurrency taxed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The IRS treats cryptocurrency as property, not currency. Every sale, exchange, or use of crypto to purchase goods is a taxable event. Short-term and long-term capital gains rules apply the same way as with stocks and other assets."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Net Investment Income Tax (NIIT)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The NIIT is an additional 3.8% tax that applies to net investment income for taxpayers whose modified AGI exceeds $200,000 (single) or $250,000 (married filing jointly). It applies on top of regular capital gains rates."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a home sale exclusion for capital gains?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If you sell your primary residence and have lived in it for at least 2 of the last 5 years, you may exclude up to $250,000 of gain ($500,000 for married filing jointly) from capital gains tax. Enter only the taxable gain after the exclusion in this calculator."
      }
    },
    {
      "@type": "Question",
      "name": "What is my cost basis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your cost basis is generally what you originally paid for the asset, including commissions. For real estate, it includes purchase price plus capital improvements. For mutual funds, it may include reinvested dividends. Using the correct cost basis is essential for an accurate gain calculation."
      }
    }
    ]
  }
  </script>
