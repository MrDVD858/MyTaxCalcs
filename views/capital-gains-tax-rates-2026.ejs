              <tr><td class="rate rate-20">20%</td><td class="range">Over ~$580,900 <span class="proj-note-inline">projected</span></td><td class="note">Was $566,700 in 2025</td></tr>
            </tbody>
          </table>
        </div>

        <div class="bracket-table-wrap" id="bracket-mfs">
          <table class="bracket-table">
            <thead><tr><th>Rate</th><th>Projected Threshold</th><th>2025 Actual</th></tr></thead>
