              <tr><td class="rate rate-0">0%</td><td class="range">Up to ~$49,500 <span class="proj-note-inline">projected</span></td><td class="note">Was $48,350 in 2025</td></tr>
              <tr><td class="rate rate-15">15%</td><td class="range">~$49,500 to ~$307,500 <span class="proj-note-inline">projected</span></td><td class="note">Was $48,350 to $300,000 in 2025</td></tr>
              <tr><td class="rate rate-20">20%</td><td class="range">Over ~$307,500 <span class="proj-note-inline">projected</span></td><td class="note">Was $300,000 in 2025</td></tr>
