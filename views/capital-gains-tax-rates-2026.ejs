  <script>
    function showBracket(id, el) {
      document.querySelectorAll('.bracket-table-wrap').forEach(function(w){w.classList.remove('active');});
      document.querySelectorAll('.bracket-tab').forEach(function(t){t.classList.remove('active');});
      document.getElementById('bracket-' + id).classList.add('active');
      el.classList.add('active');
    }
    (function(){
      var items=document.querySelectorAll('.faq-item');
      items.forEach(function(item){
        var btn=item.querySelector('.faq-question');
        btn.addEventListener('click',function(){
          var isOpen=item.classList.contains('open');
          items.forEach(function(i){i.classList.remove('open');i.querySelector('.faq-question').setAttribute('aria-expanded','false');});
          if(!isOpen){item.classList.add('open');btn.setAttribute('aria-expanded','true');}
        });
      });
    })();
  </script>
