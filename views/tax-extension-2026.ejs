  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [      {
        "@type": "Question",
        "name": "How do I file for a tax extension in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "File Form 4868 (Application for Automatic Extension of Time to File) electronically through IRS Free File, tax software, or a tax professional, or mail a paper Form 4868 by April 15, 2026. The extension is automatic — the IRS does not send a confirmation. You must still pay your estimated tax liability by April 15 to avoid the failure-to-pay penalty."
        }
      },
      {
        "@type": "Question",
        "name": "Does a tax extension give me more time to pay?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. A tax extension only extends the time to file your return — not the time to pay. If you owe taxes for 2025, you must pay at least 90% of the amount owed by April 15, 2026 to avoid the failure-to-pay penalty. Any unpaid balance after April 15 accrues interest and the 0.5% per month failure-to-pay penalty regardless of whether you filed an extension."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a penalty for filing a tax extension?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There is no penalty for filing a tax extension request itself — it is free and automatically approved. However, if you owe taxes and do not pay by April 15, the failure-to-pay penalty applies at 0.5% per month on the unpaid amount, plus interest. The failure-to-file penalty (5% per month) is avoided entirely by filing the extension by April 15, which is the main benefit."
        }
      }]
  }
