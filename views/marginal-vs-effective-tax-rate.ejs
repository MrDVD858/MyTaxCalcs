    "mainEntity": [      {
        "@type": "Question",
        "name": "What is a marginal tax rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your marginal tax rate is the rate applied to the last dollar of your taxable income — the rate of the highest tax bracket your income reaches. In the US progressive system, not all of your income is taxed at this rate. Only the income within that top bracket is taxed at the marginal rate."
        }
      },
      {
        "@type": "Question",
        "name": "What is an effective tax rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your effective tax rate is your total federal income tax divided by your gross income, expressed as a percentage. Because the US tax system taxes different portions of income at different rates, your effective rate is always lower than your marginal rate. It represents your actual average rate across all income."
        }
      },
      {
        "@type": "Question",
        "name": "Which rate — marginal or effective — should I use for financial decisions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use your marginal rate when making decisions about additional income, such as Roth conversions, freelance work, or retirement withdrawals — it shows the tax cost of the next dollar. Use your effective rate when comparing your overall tax burden year over year or describing your general tax situation."
        }
      }]
  }
