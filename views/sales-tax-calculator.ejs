  <main>
    <div class="calc-page">

      <div class="calc-page-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
          Purchase Tax Estimator
        </div>
        <h1>Sales Tax Calculator</h1>
        <p>Estimate sales tax and your final purchase total using a state rate, local rate, and optional discount. Works for any state.</p>
      </div>

      <% if (result) { %>
      <div class="result-card">
        <div class="result-card-header">
          <div class="result-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
