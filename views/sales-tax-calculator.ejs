              <label for="purchaseAmount">Purchase Amount</label>
              <div class="input-wrap"><span class="input-prefix">$</span>
                <input type="number" id="purchaseAmount" name="purchaseAmount" min="0" step="0.01" value="<%= form.purchaseAmount || '' %>" placeholder="250.00" required>
              </div>
            </div>
