<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %> | MyTaxCalcs</title>
  <meta name="description" content="Use the free sales tax calculator to estimate sales tax, combined tax rate, taxable amount, discounts, and final purchase total.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/california-income-tax-calculator">States</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
    </nav>
  </header>

  <section class="calc-hero">
    <div class="calc-hero-inner">
      <div class="section-label">Purchase Tax Estimator</div>
      <h1>Sales Tax Calculator</h1>
      <p>Estimate sales tax and final purchase total using a state rate, local rate, and optional discount.</p>
    </div>
  </section>

  <main class="calc-main">
    <div class="calc-layout">
      <section class="calc-form-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#fdf4ff; color:#9333ea;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
          </div>
          <h2>Purchase Information</h2>
        </div>
        <form method="POST" action="/sales-tax-calculator" class="calc-form">
          <div class="form-group">
            <label>Purchase Amount</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="purchaseAmount" value="<%= form.purchaseAmount || '' %>" placeholder="250.00" step="0.01" required></div>
          </div>
          <div class="form-group">
            <label>Discount Amount</label>
            <div class="input-wrap"><span class="input-prefix">$</span>
            <input type="number" name="discountAmount" value="<%= form.discountAmount || '' %>" placeholder="0.00" step="0.01"></div>
          </div>
          <div class="form-group">
            <label>State Sales Tax Rate (%)</label>
            <div class="input-wrap"><span class="input-prefix">%</span>
            <input type="number" name="stateTaxRate" value="<%= form.stateTaxRate || '' %>" placeholder="7.25" step="0.001" required></div>
          </div>
          <div class="form-group">
            <label>Local / Additional Tax Rate (%)</label>
            <div class="input-wrap"><span class="input-prefix">%</span>
            <input type="number" name="localTaxRate" value="<%= form.localTaxRate || '' %>" placeholder="1.00" step="0.001"></div>
          </div>
          <button type="submit" class="calc-submit-btn">Calculate Sales Tax <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        </form>
      </section>

      <section class="calc-results-card">
        <div class="calc-form-header">
          <div class="calc-form-icon" style="background:#fdf4ff; color:#9333ea;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h2>Estimated Results</h2>
        </div>
        <% if (!result) { %>
          <div class="results-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
            <p>Enter a purchase amount and sales tax rate to estimate your total.</p>
          </div>
        <% } else { %>
          <div class="results-grid">
            <div class="result-row"><span>Purchase Amount</span><strong>$<%= result.purchaseAmount.toFixed(2) %></strong></div>
            <div class="result-row"><span>Discount Amount</span><strong>$<%= result.discountAmount.toFixed(2) %></strong></div>
            <div class="result-row"><span>Taxable Amount</span><strong>$<%= result.taxableAmount.toFixed(2) %></strong></div>
            <div class="result-row"><span>State Sales Tax Rate</span><strong><%= result.stateTaxRate.toFixed(3) %>%</strong></div>
            <div class="result-row"><span>Local / Additional Rate</span><strong><%= result.localTaxRate.toFixed(3) %>%</strong></div>
            <div class="result-row"><span>Combined Tax Rate</span><strong><%= result.combinedTaxRate.toFixed(3) %>%</strong></div>
            <div class="result-row"><span>Estimated Sales Tax</span><strong>$<%= result.salesTax.toFixed(2) %></strong></div>
            <div class="result-row result-highlight refund">
              <span>Final Total</span>
              <strong>$<%= result.finalTotal.toFixed(2) %></strong>
            </div>
          </div>
        <% } %>
        <div class="results-disclaimer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Estimate only. Actual sales tax may vary by location, item type, exemption, and local rules.
        </div>
      </section>
    </div>

    <div class="calc-content-wrapper">
      <section class="content seo-content">
        <p class="eyebrow dark">Sales Tax Guide</p>
        <h2>How this sales tax calculator works</h2>
        <p>This calculator estimates sales tax by applying a combined tax rate to the taxable purchase amount. You can enter a state sales tax rate, local or additional tax rate, and optional discount to estimate the final purchase total.</p>
        <div class="seo-grid">
          <div class="seo-mini-card"><h3>Taxable amount</h3><p>The taxable amount is the purchase amount after subtracting the discount amount entered. This calculator applies the tax rate to that taxable amount.</p></div>
          <div class="seo-mini-card"><h3>Combined rate</h3><p>The combined rate is the state sales tax rate plus any local, city, county, or additional rate you enter.</p></div>
          <div class="seo-mini-card"><h3>Final total</h3><p>The final total is the taxable amount plus the estimated sales tax. Actual totals may vary depending on local rules and item exemptions.</p></div>
        </div>
        <h2>Sales tax FAQ</h2>
        <div class="faq-list">
          <div class="faq-item"><h3>What is sales tax?</h3><p>Sales tax is a tax applied to certain purchases. The rate can vary by state, city, county, district, and item type.</p></div>
          <div class="faq-item"><h3>Does this calculator automatically know my local tax rate?</h3><p>No. This version uses the rates you enter. That helps keep the calculator flexible because sales tax rates can vary by exact location.</p></div>
          <div class="faq-item"><h3>What is a combined sales tax rate?</h3><p>A combined sales tax rate is the total of the state rate plus any local or additional rates that apply to the purchase.</p></div>
          <div class="faq-item"><h3>Are all purchases taxable?</h3><p>No. Some items may be exempt, partially exempt, or taxed differently depending on the state and local rules. Examples may include groceries, medicine, clothing, or services.</p></div>
          <div class="faq-item"><h3>Can I use this for business tax filing?</h3><p>No. This calculator is for educational estimates only. Businesses should use official state and local tax guidance, tax software, or a qualified tax professional.</p></div>
        </div>
        <p class="last-updated">Last updated: April 2026</p>
      </section>
      <section class="content related-calculators">
        <p class="eyebrow dark">Related Calculators</p>
        <h2>More tax calculators</h2>
        <div class="related-grid">
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
          <a href="/calculators">All Calculators</a>
        </div>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/california-income-tax-calculator">State Tax Calculators</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom"><p>© 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>
</body>
</html>
