              <label for="discountAmount">Discount Amount</label>
              <div class="input-wrap"><span class="input-prefix">$</span>
                <input type="number" id="discountAmount" name="discountAmount" min="0" step="0.01" value="<%= form.discountAmount || '' %>" placeholder="0.00">
