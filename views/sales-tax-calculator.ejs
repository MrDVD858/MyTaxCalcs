        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
    </nav>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <a href="/calculators">Calculators</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <span>Sales Tax Calculator</span>
  </nav>

  <main>
    <div class="calc-page">

      <div class="calc-page-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
          Purchase Tax Estimator
        </div>
        <h1>Sales Tax Calculator</h1>
        <p>Estimate sales tax and your final purchase total using a state rate, local rate, and optional discount. Works for any state.</p>
      </div>

      <% if (result) { %>
      <div class="result-card">
        <div class="result-card-header">
          <div class="result-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
          </div>
          <h2>Your Sales Tax Estimate</h2>
        </div>
        <div class="result-primary">
          <span class="result-label">Final Total (with tax)</span>
          <span class="result-amount">$<%= result.finalTotal.toFixed(2) %></span>
        </div>
        <div class="result-grid">
          <div class="result-item">
            <div class="ri-label">Purchase Amount</div>
            <div class="ri-value">$<%= result.purchaseAmount.toFixed(2) %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Discount Amount</div>
            <div class="ri-value">$<%= result.discountAmount.toFixed(2) %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Taxable Amount</div>
            <div class="ri-value">$<%= result.taxableAmount.toFixed(2) %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Combined Tax Rate</div>
            <div class="ri-value"><%= result.combinedTaxRate.toFixed(3) %>%</div>
          </div>
          <div class="result-item">
            <div class="ri-label">State Rate</div>
            <div class="ri-value"><%= result.stateTaxRate.toFixed(3) %>%</div>
          </div>
          <div class="result-item">
            <div class="ri-label">Estimated Sales Tax</div>
            <div class="ri-value">$<%= result.salesTax.toFixed(2) %></div>
          </div>
        </div>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

      <div class="calc-card-form">
        <h2>Enter Purchase Details</h2>
        <form method="POST" action="/sales-tax-calculator">
          <div class="form-grid">
            <div class="form-field">
              <label for="purchaseAmount">Purchase Amount</label>
              <div class="input-wrap"><span class="input-prefix">$</span>
                <input type="number" id="purchaseAmount" name="purchaseAmount" min="0" step="0.01" value="<%= form.purchaseAmount || '' %>" placeholder="250.00" required>
              </div>
            </div>
            <div class="form-field">
              <label for="discountAmount">Discount Amount</label>
              <div class="input-wrap"><span class="input-prefix">$</span>
                <input type="number" id="discountAmount" name="discountAmount" min="0" step="0.01" value="<%= form.discountAmount || '' %>" placeholder="0.00">
              </div>
            </div>
            <div class="form-field">
              <label for="stateTaxRate">State Sales Tax Rate (%)</label>
              <div class="input-wrap"><span class="input-prefix">%</span>
                <input type="number" id="stateTaxRate" name="stateTaxRate" min="0" step="0.001" value="<%= form.stateTaxRate || '' %>" placeholder="7.25" required>
              </div>
            </div>
            <div class="form-field">
              <label for="localTaxRate">Local / Additional Tax Rate (%)</label>
              <div class="input-wrap"><span class="input-prefix">%</span>
                <input type="number" id="localTaxRate" name="localTaxRate" min="0" step="0.001" value="<%= form.localTaxRate || '' %>" placeholder="1.00">
              </div>
            </div>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-calc">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
              Calculate Sales Tax
            </button>
          </div>
        </form>
      </div>

      <div class="hiw-section">
        <div class="section-eyebrow">How It Works</div>
        <h2>How Sales Tax Is Calculated</h2>
        <p>Sales tax is calculated on the taxable purchase amount after any discount, using the combined state and local rate you enter.</p>
        <div class="hiw-steps">
          <div class="hiw-step">
            <div class="hiw-step-num">1</div>
            <div class="hiw-step-body">
              <h3>Find the Taxable Amount</h3>
              <p>Start with the full purchase price and subtract any discount. The remaining amount is what sales tax is applied to.</p>
            </div>
          </div>
          <div class="hiw-step">
            <div class="hiw-step-num">2</div>
            <div class="hiw-step-body">
              <h3>Add State and Local Rates</h3>
              <p>The combined tax rate is your state rate plus any city, county, or district tax rate. Rates vary widely by location.</p>
            </div>
          </div>
          <div class="hiw-step">
            <div class="hiw-step-num">3</div>
            <div class="hiw-step-body">
              <h3>Calculate the Tax Amount</h3>
              <p>Multiply the taxable amount by the combined rate (as a decimal) to get the estimated sales tax dollar amount.</p>
            </div>
          </div>
          <div class="hiw-step">
            <div class="hiw-step-num">4</div>
            <div class="hiw-step-body">
              <h3>Calculate the Final Total</h3>
              <p>Add the estimated sales tax to the taxable amount to get the final out-of-pocket cost.</p>
            </div>
          </div>
        </div>
        <div class="formula-box">
          <div class="formula-box-label">Formula Reference</div>
          <code><span class="comment">// Step 1 - Taxable Amount</span>
<span class="highlight">Taxable Amount</span>   = Purchase Amount - Discount Amount

<span class="comment">// Step 2 - Combined Rate</span>
<span class="highlight">Combined Rate</span>    = State Rate + Local Rate

<span class="comment">// Step 3 - Sales Tax</span>
<span class="highlight">Sales Tax</span>        = Taxable Amount x (Combined Rate / 100)

<span class="comment">// Step 4 - Final Total</span>
<span class="highlight">Final Total</span>      = Taxable Amount + Sales Tax</code>
        </div>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="faq-section">
        <div class="section-eyebrow">FAQ</div>
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">What is sales tax?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">Sales tax is a consumption tax added to the price of certain goods and services at the point of sale. It is collected by the seller and remitted to the state and local governments. Rates and taxable items vary significantly by state and locality.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">How do I find my local sales tax rate?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">You can find your combined state and local sales tax rate on your state's department of revenue website, or by entering your address into the IRS sales tax deduction calculator. Rates can vary by city, county, and special tax district even within the same state.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Are all purchases subject to sales tax?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">No. Many states exempt certain items from sales tax. Common exemptions include unprepared groceries, prescription medications, medical equipment, and some clothing. Exemption rules vary by state and product category.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Does online shopping include sales tax?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">Yes. Following a 2018 Supreme Court ruling, states can require online sellers to collect and remit sales tax even without a physical presence in the state. Most major online retailers now collect sales tax based on your shipping address.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Which states have no sales tax?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">Five states have no state-level sales tax: Alaska, Delaware, Montana, New Hampshire, and Oregon. However, Alaska allows local jurisdictions to impose their own sales taxes, so rates can still apply in some Alaska localities.</div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">Can I deduct sales tax on my federal return?<span class="faq-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span></button>
            <div class="faq-answer">If you itemize deductions, you may be able to deduct either state income taxes or state and local sales taxes paid, but not both. The combined deduction for state and local taxes is capped at $10,000 per year. Consult a tax professional to determine what is best for your situation.</div>
          </div>
        </div>
      </div>

      <div class="related-section">
        <h2>Related Tax Calculators</h2>
        <div class="related-grid">
          <a class="related-card" href="/income-tax-calculator">
            <div class="related-card-icon" style="background:#ecfdf5;color:#16a34a;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M7 8h4M7 12h8"/></svg></div>
            <strong>Income Tax Calculator</strong>
            <span>Estimate annual federal tax and effective rate</span>
          </a>
          <a class="related-card" href="/tax-refund-calculator">
            <div class="related-card-icon" style="background:#f0fdf4;color:#15803d;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
            <strong>Tax Refund Calculator</strong>
            <span>Estimate your refund or balance owed</span>
          </a>
          <a class="related-card" href="/capital-gains-tax-calculator">
            <div class="related-card-icon" style="background:#fef3c7;color:#d97706;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/></svg></div>
            <strong>Capital Gains Tax</strong>
            <span>Estimate tax on asset sales and investments</span>
