  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="Free Sales Tax Calculator | MyTaxCalcs">
  <meta property="og:description" content="Estimate sales tax, combined tax rate, discount amount, and final purchase total instantly.">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Free Sales Tax Calculator | MyTaxCalcs">
  <meta name="twitter:description" content="Estimate sales tax and final purchase total for any state or local tax rate.">
