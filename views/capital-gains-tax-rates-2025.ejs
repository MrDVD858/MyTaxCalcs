  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the capital gains tax rates for 2025?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For 2025, long-term capital gains rates are 0%, 15%, or 20% depending on your total taxable income and filing status. Single filers pay 0% on gains if taxable income is up to $48,350, 15% up to $533,400, and 20% above that. Short-term gains on assets held one year or less are taxed as ordinary income using the standard federal tax brackets."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Net Investment Income Tax (NIIT)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The NIIT is an additional 3.8% tax on net investment income for higher earners. It applies to single filers with modified adjusted gross income above $200,000 and married filing jointly above $250,000. Capital gains count as investment income for NIIT purposes, so high earners can face an effective rate of up to 23.8% on long-term gains."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between short-term and long-term capital gains?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Short-term capital gains apply to assets held one year or less and are taxed at your ordinary income tax rate, up to 37%. Long-term capital gains apply to assets held longer than one year and benefit from preferential rates of 0%, 15%, or 20%, which are significantly lower than ordinary income rates for most taxpayers."
        }
      }
    ]
  }
  </script>
