    .contact-submit{align-self:flex-start;background:#16a34a;color:#fff;padding:12px 28px;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;transition:background .15s}
    .contact-submit:hover{background:#15803d}
    .contact-success{display:none;background:#f0fdf4;border:1px solid #d1fae5;border-radius:12px;padding:20px 24px;margin-top:16px;font-size:.95rem;color:#166534;font-weight:600}
  </style>
