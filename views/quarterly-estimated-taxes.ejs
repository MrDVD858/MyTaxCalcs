  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "When are quarterly estimated taxes due in 2025?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 2025 quarterly estimated tax due dates are: April 15, 2025 (Q1), June 16, 2025 (Q2), September 15, 2025 (Q3), and January 15, 2026 (Q4). If a due date falls on a weekend or holiday, it moves to the next business day."
        }
      },
      {
        "@type": "Question",
        "name": "Who has to pay quarterly estimated taxes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You generally must pay quarterly estimated taxes if you expect to owe at least $1,000 in federal tax after withholding and credits, and your withholding covers less than 90% of your current year tax or 100% of last year's tax (110% if AGI exceeded $150,000). This commonly applies to self-employed individuals, freelancers, investors, retirees, and anyone with significant income not subject to withholding."
        }
      },
      {
        "@type": "Question",
        "name": "What is the safe harbor for quarterly estimated taxes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The safe harbor rule lets you avoid underpayment penalties by paying at least 100% of last year's tax liability in equal quarterly installments (or 110% if your prior year AGI exceeded $150,000). Alternatively, pay at least 90% of the current year's actual tax liability. Meeting either threshold avoids the underpayment penalty even if you owe at filing."
        }
      }
    ]
  }
  </script>
