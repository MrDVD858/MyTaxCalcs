  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Should I take the standard deduction or itemize in 2025?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Take whichever produces the larger deduction. In 2025, the standard deduction is $15,000 for single filers and $30,000 for married filing jointly. If your total eligible itemized deductions including mortgage interest, state and local taxes (up to $10,000), and charitable contributions exceed your standard deduction, itemizing saves more tax. About 90% of taxpayers take the standard deduction."
        }
      },
      {
        "@type": "Question",
        "name": "What counts as an itemized deduction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common itemized deductions include mortgage interest on your primary and secondary home, state and local income or sales taxes plus property taxes (combined cap of $10,000), charitable contributions to qualifying organizations, and medical expenses exceeding 7.5% of your adjusted gross income. Miscellaneous deductions subject to the 2% AGI floor were largely eliminated after 2017."
        }
      },
      {
        "@type": "Question",
        "name": "Can I switch between standard and itemized deductions each year?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You choose your deduction method each year when you file. There is no requirement to use the same method year after year. Many taxpayers switch to itemizing in years when they have large charitable gifts, high medical expenses, or significant mortgage interest, then switch back to the standard deduction in other years."
        }
      }
    ]
  }
