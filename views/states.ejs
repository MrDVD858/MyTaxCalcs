<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "State Income Tax Calculators",
    "url": "https://mytaxcalcs.com/states",
    "description": "Free income tax calculators for all 50 U.S. states. Estimate 2025 federal income tax and review state-specific tax rates.",
    "publisher": { "@type": "Organization", "name": "MyTaxCalcs" }
  }
  </script>
  <style>
    .breadcrumb{max-width:1100px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db;font-size:.75rem}
    .states-page{max-width:1100px;margin:0 auto;padding:0 24px 60px}
    .states-page-header{padding:36px 0 28px}
    .page-eyebrow{display:inline-flex;align-items:center;gap:6px;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:4px 12px;margin-bottom:12px}
    .states-page-header h1{font-size:2rem;font-weight:800;line-height:1.2;margin:0 0 10px;color:#111827}
    .states-page-header p{font-size:1rem;color:#6b7280;margin:0;max-width:600px}
    .section-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;margin-bottom:16px}
    .states-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:48px}
    @media(max-width:800px){.states-grid{grid-template-columns:repeat(3,1fr)}}
    @media(max-width:560px){.states-grid{grid-template-columns:repeat(2,1fr)}}
    .state-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:16px 14px;text-decoration:none;color:inherit;transition:border-color .15s,box-shadow .15s,transform .15s;display:flex;flex-direction:column;gap:4px}
    .state-card:hover{border-color:#16a34a;box-shadow:0 4px 12px rgba(22,163,74,.1);transform:translateY(-2px)}
    .state-card-name{font-size:.9rem;font-weight:700;color:#111827}
    .state-card-rate{font-size:.78rem;color:#6b7280}
    .state-card-badge{font-size:.68rem;font-weight:700;padding:2px 7px;border-radius:20px;display:inline-block;width:fit-content;margin-top:2px}
    .badge-notax{background:#ecfdf5;color:#15803d}
    .badge-hastax{background:#f0f9ff;color:#0369a1}
    .intro-box{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:20px 24px;margin-bottom:32px}
    .intro-box p{font-size:.92rem;color:#0f172a;line-height:1.7;margin:0}
    .ad-zone{text-align:center;margin:0 auto 40px;max-width:1100px;min-height:90px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    .page-disclaimer{margin:40px 0 0;background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;padding:16px 20px;display:flex;gap:10px;align-items:flex-start}
    .page-disclaimer svg{color:#9ca3af;min-width:18px;margin-top:1px}
    .page-disclaimer p{font-size:.82rem;color:#6b7280;margin:0;line-height:1.55}
  </style>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states" aria-current="page">States</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/income-tax-calculator">Get Started</a>
    </nav>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <span>State Income Tax Calculators</span>
  </nav>

  <main>
    <div class="states-page">

      <div class="states-page-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          All 50 States
        </div>
        <h1>State Income Tax Calculators</h1>
        <p>Choose your state to estimate your 2025 federal income tax and review state-specific income tax rates and rules.</p>
      </div>

      <div class="intro-box">
        <p>Each state calculator estimates your <strong>federal income tax</strong> using 2025 IRS brackets and shows relevant state tax information — including the state income tax rate range, whether the state has a broad-based income tax, and key state tax notes. Nine states have no broad-based income tax: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming.</p>
      </div>

      <div class="section-label">Choose Your State</div>
      <div class="states-grid">
        <% states.forEach(function(state) { %>
          <a class="state-card" href="/<%= state.slug %>-income-tax-calculator">
            <span class="state-card-name"><%= state.name %></span>
            <% if (state.hasIncomeTax) { %>
              <span class="state-card-rate"><%= state.brackets %></span>
              <span class="state-card-badge badge-hastax">Has income tax</span>
            <% } else { %>
              <span class="state-card-rate">No income tax</span>
              <span class="state-card-badge badge-notax">No income tax</span>
            <% } %>
          </a>
        <% }) %>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="page-disclaimer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p><strong>Disclaimer:</strong> These calculators estimate federal income tax only using 2025 IRS brackets. State tax rates shown are for reference only and may not reflect all local taxes, credits, or deductions. Not tax, legal, or financial advice. Consult a qualified tax professional before making tax decisions.</p>
      </div>

    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>
            MyTaxCalcs
          </a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p>
      </div>
    </div>
  </footer>

</body>
</html>
