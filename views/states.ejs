  <meta name="description" content="<%= metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= ogTitle %>">
  <meta name="twitter:description" content="<%= ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <style>
    .ad-zone{text-align:center;margin:8px 0;min-height:0}
    .ad-zone-label{font-size:.62rem;color:#b0bbc9;text-transform:uppercase;letter-spacing:.09em;margin-bottom:3px;font-weight:600}
  </style>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="nav-mobile-drawer" id="nav-mobile-drawer" role="navigation" aria-label="Mobile navigation">
      <div class="nav-mobile-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-mobile-cta" href="/calculators">All Calculators</a>
    </div>
  </header>

  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-glow"></div>
    <div class="page-hero-inner">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="hbc-sep">&#8250;</span>
        <span class="hbc-current">State Income Tax Calculators</span>
      </nav>
      <div class="page-hero-eyebrow">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        50-State Directory
      </div>
      <h1>State Income Tax Calculators</h1>
      <p>Choose your state to review income tax rates, brackets, and filing details for 2025 &mdash; plus a free federal income tax estimate.</p>
      <div class="blog-hero-stats">
        <div class="blog-hero-stat"><strong>50</strong> states covered</div>
        <div class="blog-hero-sep"></div>
        <div class="blog-hero-stat">2025 tax year data</div>
        <div class="blog-hero-sep"></div>
        <div class="blog-hero-stat">Always free</div>
      </div>
    </div>
  </section>

  <div class="page-with-sidebar">
  <main>
    <div class="states-page-content">

      <div class="ad-zone" style="margin:20px 0">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block" id="ad-slot-1"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>
          (function() {
            var ins = document.getElementById('ad-slot-1');
            if (!ins) return;
            var obs = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) { (adsbygoogle = window.adsbygoogle || []).push({}); obs.disconnect(); }
            }, { rootMargin: '200px' });
            obs.observe(ins);
          })();
        </script>
      </div>

      <!-- CALLOUT CARDS: no-tax, high-tax, popular, tip -->
      <div class="states-callout-grid">
        <div class="state-callout-card no-tax">
          <div class="scc-icon">&#127381;</div>
          <p class="scc-title">No State Income Tax</p>
          <p class="scc-desc">These 9 states have no individual income tax &mdash; residents pay only federal tax on wages.</p>
          <div class="scc-links">
            <a href="/texas-income-tax-calculator" class="scc-link">Texas</a>
            <a href="/florida-income-tax-calculator" class="scc-link">Florida</a>
            <a href="/washington-income-tax-calculator" class="scc-link">Washington</a>
            <a href="/nevada-income-tax-calculator" class="scc-link">Nevada</a>
            <a href="/wyoming-income-tax-calculator" class="scc-link">Wyoming</a>
            <a href="/alaska-income-tax-calculator" class="scc-link">Alaska</a>
            <a href="/south-dakota-income-tax-calculator" class="scc-link">South Dakota</a>
            <a href="/tennessee-income-tax-calculator" class="scc-link">Tennessee</a>
            <a href="/new-hampshire-income-tax-calculator" class="scc-link">New Hampshire</a>
          </div>
        </div>
        <div class="state-callout-card high-tax">
          <div class="scc-icon">&#128200;</div>
          <p class="scc-title">Highest Rate States</p>
          <p class="scc-desc">These states have top marginal rates above 9% &mdash; high earners should estimate carefully.</p>
          <div class="scc-links">
            <a href="/california-income-tax-calculator" class="scc-link">California 13.3%</a>
            <a href="/hawaii-income-tax-calculator" class="scc-link">Hawaii 11%</a>
            <a href="/new-jersey-income-tax-calculator" class="scc-link">New Jersey 10.75%</a>
            <a href="/oregon-income-tax-calculator" class="scc-link">Oregon 9.9%</a>
            <a href="/minnesota-income-tax-calculator" class="scc-link">Minnesota 9.85%</a>
            <a href="/new-york-income-tax-calculator" class="scc-link">New York 10.9%</a>
          </div>
        </div>
        <div class="state-callout-card popular">
          <div class="scc-icon">&#127968;</div>
          <p class="scc-title">Most Searched States</p>
          <p class="scc-desc">The most visited state calculator pages on MyTaxCalcs by U.S. residents estimating their taxes.</p>
          <div class="scc-links">
            <a href="/california-income-tax-calculator" class="scc-link">California</a>
            <a href="/new-york-income-tax-calculator" class="scc-link">New York</a>
            <a href="/texas-income-tax-calculator" class="scc-link">Texas</a>
            <a href="/florida-income-tax-calculator" class="scc-link">Florida</a>
            <a href="/illinois-income-tax-calculator" class="scc-link">Illinois</a>
            <a href="/pennsylvania-income-tax-calculator" class="scc-link">Pennsylvania</a>
          </div>
        </div>
        <div class="state-callout-card tip">
          <div class="scc-icon">&#128161;</div>
          <p class="scc-title">State Tax Tip</p>
          <p class="scc-desc">State income tax is on top of your federal bill. Most states also have local taxes. Always estimate both layers before setting your withholding.</p>
          <div class="scc-links">
            <a href="/income-tax-calculator" class="scc-link">Federal Calculator</a>
            <a href="/tax-brackets-2025" class="scc-link">2025 Brackets</a>
          </div>
        </div>
      </div>

      <!-- FILTER + GRID -->
      <div class="states-filter-bar">
        <input type="text" class="states-search" id="state-search" placeholder="Search states..." aria-label="Filter states">
        <span class="states-count" id="states-shown">Showing all 50 states</span>
      </div>

      <div class="states-grid-premium" id="states-grid">
        <% states.forEach(function(item) { %>
          <a href="/<%= item.slug %>-income-tax-calculator" class="state-card-premium" data-name="<%= item.name.toLowerCase() %> <%= item.abbr.toLowerCase() %>">
            <span class="scn"><%= item.name %></span>
            <span class="sca"><%= item.abbr %></span>
          </a>
        <% }) %>
      </div>

      <div class="ad-zone" style="margin-top:36px">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block" id="ad-slot-2"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>
          (function() {
            var ins = document.getElementById('ad-slot-2');
            if (!ins) return;
            var obs = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) { (adsbygoogle = window.adsbygoogle || []).push({}); obs.disconnect(); }
            }, { rootMargin: '200px' });
            obs.observe(ins);
          })();
        </script>
      </div>

      <div class="states-seo-section">
        <h2>State Income Tax: What to Know for 2025</h2>
        <p>State income tax rates vary widely &mdash; from 0% in states like Texas, Florida, and Wyoming, to over 13% in California. Use each state calculator page to see local brackets, rates, standard deductions, and filing thresholds for 2025. All federal income tax estimates use the same 2025 IRS brackets.</p>
      </div>

    </div>
  </main>
  <aside class="sidebar-ad-col" aria-label="Advertisement" aria-hidden="true">
    <div class="sidebar-ad-inner">
      <p class="sidebar-ad-label">Ad</p>
      <ins class="adsbygoogle"
           style="display:block;width:160px;min-height:600px"
           data-ad-client="ca-pub-5193834725888549"
           data-ad-slot="4041103773"
           data-ad-format="auto"
           data-full-width-responsive="false"></ins>
      <script>
        (function(){
          var ins=document.currentScript.previousElementSibling;
          var io=new IntersectionObserver(function(entries,observer){
            if(entries[0].isIntersecting){(adsbygoogle=window.adsbygoogle||[]).push({});observer.disconnect();}
          },{rootMargin:'200px'});
          io.observe(ins);
        })();
      </script>
    </div>
  </aside>
</div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom"><p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>

  <script>
    (function() {
      var btn = document.querySelector('.nav-hamburger');
      var drawer = document.getElementById('nav-mobile-drawer');
      if (!btn || !drawer) return;
      btn.addEventListener('click', function() {
        var open = drawer.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
      document.addEventListener('click', function(e) {
        if (!btn.contains(e.target) && !drawer.contains(e.target)) {
          drawer.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Open menu');
        }
      });
    })();
    // State search filter
    (function() {
      var input = document.getElementById('state-search');
      var cards = document.querySelectorAll('#states-grid .state-card-premium');
      var countEl = document.getElementById('states-shown');
      if (!input) return;
      input.addEventListener('input', function() {
        var q = input.value.trim().toLowerCase();
        var shown = 0;
        cards.forEach(function(card) {
          var name = card.getAttribute('data-name') || '';
          var visible = !q || name.indexOf(q) > -1;
          card.style.display = visible ? '' : 'none';
          if (visible) shown++;
        });
        countEl.textContent = q ? 'Showing ' + shown + ' of 50 states' : 'Showing all 50 states';
      });
    })();
  </script>
</body>
</html>
