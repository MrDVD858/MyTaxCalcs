  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between a W-2 and a 1099?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A W-2 is issued by an employer to an employee and shows wages paid and taxes withheld. A 1099-NEC is issued to independent contractors showing non-employee compensation with no taxes withheld. W-2 employees have Social Security, Medicare, and federal income tax withheld from each paycheck. 1099 contractors receive gross pay with no withholding and must pay self-employment tax plus make quarterly estimated tax payments."
        }
      },
      {
        "@type": "Question",
        "name": "Do 1099 contractors pay more tax than W-2 employees?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "At the same income level, 1099 contractors generally pay more in taxes than W-2 employees because they pay the full 15.3% self-employment tax covering both employer and employee FICA shares. W-2 employees only pay 7.65% because their employer covers the other half. However, contractors can deduct business expenses and half of SE tax, partially offsetting the difference."
        }
      },
      {
        "@type": "Question",
        "name": "Can I have both W-2 and 1099 income?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Many people have a W-2 job and also do freelance or contract work that generates 1099 income. Both types of income are reported on the same federal tax return. W-2 withholding may not cover the taxes on your 1099 income, so you may need to make quarterly estimated payments or increase your W-4 withholding at your employer."
        }
      }
    ]
  }
  </script>
