  <!-- Calculator JS -->
  <script>
    document.getElementById('calculate-btn').addEventListener('click', function () {
      const gross = parseFloat(document.getElementById('gross-income').value) || 0;
      const expenses = parseFloat(document.getElementById('expenses').value) || 0;
      const SS_WAGE_BASE = 176100;

      const netIncome = Math.max(0, gross - expenses);
      const seTaxable = netIncome * 0.9235;
      const ssTaxable = Math.min(seTaxable, SS_WAGE_BASE);
      const ssTax = ssTaxable * 0.124;
      const medicareTax = seTaxable * 0.029;
      const totalSeTax = ssTax + medicareTax;
      const deductibleHalf = totalSeTax * 0.5;
      const quarterlyPayment = totalSeTax / 4;

      const fmt = v => '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

      document.getElementById('net-income').textContent = fmt(netIncome);
      document.getElementById('se-taxable').textContent = fmt(seTaxable);
      document.getElementById('ss-tax').textContent = fmt(ssTax);
      document.getElementById('medicare-tax').textContent = fmt(medicareTax);
      document.getElementById('total-se-tax').textContent = fmt(totalSeTax);
      document.getElementById('deductible-half').textContent = fmt(deductibleHalf);
      document.getElementById('quarterly-payment').textContent = fmt(quarterlyPayment);

      document.getElementById('results').style.display = 'block';
    });
  </script>

