            var obs = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) {
                (adsbygoogle = window.adsbygoogle || []).push({});
                obs.disconnect();
              }
            }, { rootMargin: '200px' });
            obs.observe(ins);
          })();
