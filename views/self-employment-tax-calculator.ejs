  <main>
    <div class="calc-page">

      <div class="calc-page-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Contractor Estimator
        </div>
        <h1>Self-Employment Tax Calculator</h1>
        <p>Estimate your 2025 Social Security and Medicare obligations, tax-deductible portions, and net income margins for 1099 freelance earnings.</p>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block" id="ad-slot-1"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>
          (function() {
            var ins = document.getElementById('ad-slot-1');
            if (!ins) return;
            var obs = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) {
                (adsbygoogle = window.adsbygoogle || []).push({});
                obs.disconnect();
              }
            }, { rootMargin: '200px' });
            obs.observe(ins);
          })();
        </script>
      </div>

      <div style="margin:0 0 24px;padding:16px 0;border-bottom:1px solid #e5e7eb;">
        <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#16a34a;margin:0 0 10px;">Try next</p>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
        <a href="/income-tax-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">💰</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Income Tax Calculator</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">Estimate your federal tax bill</p>
          </div>
        </a>
        <a href="/tax-refund-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">💵</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Tax Refund Calculator</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">Will you get a refund?</p>
          </div>
        </a>
        <a href="/payroll-tax-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">💼</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Payroll Tax Calculator</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">Employer & employee taxes</p>
          </div>
        </a>
        </div>
      </div>

      <% if (result) { %>
      <div class="result-card">
        <div class="result-card-header">
          <div class="result-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h2>Your 1099 Tax Liability Estimate</h2>
        </div>
        <div class="result-primary">
          <span class="result-label">Total Self-Employment Tax (SE)</span>
          <span class="result-amount">$<%= Math.round(result.totalSelfEmploymentTax).toLocaleString() %></span>
        </div>
        <div class="result-grid">
          <div class="result-item">
            <div class="ri-label">Gross Freelance Income</div>
            <div class="ri-value">$<%= Math.round(result.grossIncome).toLocaleString() %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Net business Profit (92.35%)</div>
            <div class="ri-value">$<%= Math.round(result.netProfit).toLocaleString() %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Social Security Tax portion (12.4%)</div>
            <div class="ri-value red">$<%= Math.round(result.socialSecurityTax).toLocaleString() %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Medicare Tax portion (2.9%)</div>
            <div class="ri-value red">$<%= Math.round(result.medicareTax).toLocaleString() %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Above-the-Line Write Off (50% Deduction)</div>
            <div class="ri-value" style="color: #16a34a;">$<%= Math.round(result.deductiblePortion).toLocaleString() %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Suggested Quarterly Payment Allocation</div>
            <div class="ri-value" style="color: #2563eb;">$<%= Math.round(result.quarterlyEstimatedPayment).toLocaleString() %></div>
          </div>
        </div>
