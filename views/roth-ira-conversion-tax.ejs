      <div class="roth-calc-wrap">
        <h2>Roth Conversion Tax Calculator</h2>
        <p class="calc-sub">Estimate the federal tax cost of converting a traditional IRA or 401(k) to a Roth IRA.</p>
        <div class="roth-calc-fields">
          <div class="roth-field">
            <label for="rc-filing">Filing Status</label>
            <select id="rc-filing">
              <option value="single">Single</option>
              <option value="mfj">Married Filing Jointly</option>
              <option value="mfs">Married Filing Separately</option>
              <option value="hoh">Head of Household</option>
            </select>
          </div>
          <div class="roth-field">
            <label for="rc-income">Other Taxable Income ($)</label>
            <input type="number" id="rc-income" placeholder="e.g. 60000" min="0" max="9999999">
          </div>
          <div class="roth-field">
            <label for="rc-conversion">Conversion Amount ($)</label>
            <input type="number" id="rc-conversion" placeholder="e.g. 20000" min="0" max="9999999">
          </div>
          <div class="roth-field">
            <label for="rc-year">Tax Year</label>
            <select id="rc-year">
              <option value="2025">2025</option>
              <option value="2026">2026</option>
            </select>
          </div>
        </div>
        <button class="roth-calc-btn" onclick="calcRothTax()">Calculate Conversion Tax</button>
        <div class="roth-result" id="roth-result">
          <div class="roth-result-grid">
            <div class="roth-result-card">
              <div class="rc-label">Extra Tax from Conversion</div>
              <div class="rc-val" id="rc-extra-tax">--</div>
            </div>
            <div class="roth-result-card">
              <div class="rc-label">Effective Rate on Conversion</div>
              <div class="rc-val" id="rc-eff-rate">--</div>
            </div>
            <div class="roth-result-card green">
              <div class="rc-label">Tax Without Conversion</div>
              <div class="rc-val" id="rc-tax-before">--</div>
            </div>
            <div class="roth-result-card green">
              <div class="rc-label">Tax With Conversion</div>
              <div class="rc-val" id="rc-tax-after">--</div>
            </div>
          </div>
          <p class="roth-result-note" id="rc-bracket-note"></p>
        </div>
      </div>

      <script>
      (function(){
        var BRACKETS = {
          2025: {
            single:    [[11925,10],[48475,12],[103350,22],[197300,24],[250525,32],[626350,35],[Infinity,37]],
            mfj:       [[23850,10],[96950,12],[206700,22],[394600,24],[501050,32],[751600,35],[Infinity,37]],
            mfs:       [[11925,10],[48475,12],[103350,22],[197300,24],[250525,32],[375800,35],[Infinity,37]],
            hoh:       [[17000,10],[64850,12],[103350,22],[197300,24],[250500,32],[626350,35],[Infinity,37]]
          },
          2026: {
            single:    [[12100,10],[49150,12],[104950,22],[200300,24],[254350,32],[635550,35],[Infinity,37]],
            mfj:       [[24200,10],[98300,12],[209850,22],[400600,24],[508700,32],[762600,35],[Infinity,37]],
            mfs:       [[12100,10],[49150,12],[104950,22],[200300,24],[254350,32],[381300,35],[Infinity,37]],
            hoh:       [[17250,10],[65900,12],[104950,22],[200300,24],[254350,32],[635550,35],[Infinity,37]]
          }
        };
        var STD_DED = {
          2025: {single:15000, mfj:30000, mfs:15000, hoh:22500},
          2026: {single:15700, mfj:31400, mfs:15700, hoh:23350}
        };
        function calcTax(taxable, brackets) {
          var tax = 0, prev = 0;
          for (var i = 0; i < brackets.length; i++) {
            var top = brackets[i][0], rate = brackets[i][1] / 100;
            if (taxable <= prev) break;
            tax += (Math.min(taxable, top) - prev) * rate;
            prev = top;
            if (taxable <= top) break;
          }
          return tax;
        }
        function fmt(n) {
          return '$' + Math.round(n).toLocaleString('en-US');
        }
        window.calcRothTax = function() {
          var filing = document.getElementById('rc-filing').value;
          var income = parseFloat(document.getElementById('rc-income').value) || 0;
          var conversion = parseFloat(document.getElementById('rc-conversion').value) || 0;
          var year = document.getElementById('rc-year').value;
          if (conversion <= 0) { alert('Please enter a conversion amount.'); return; }
          var brackets = BRACKETS[year][filing];
          var stdDed = STD_DED[year][filing];
          var taxableBefore = Math.max(0, income - stdDed);
          var taxableAfter = Math.max(0, income + conversion - stdDed);
          var taxBefore = calcTax(taxableBefore, brackets);
          var taxAfter = calcTax(taxableAfter, brackets);
          var extra = taxAfter - taxBefore;
          var effRate = conversion > 0 ? (extra / conversion * 100) : 0;
          // find marginal bracket
          var marginalRate = 0;
          var prev2 = 0;
          for (var i = 0; i < brackets.length; i++) {
            if (taxableAfter > prev2) { marginalRate = brackets[i][1]; }
            prev2 = brackets[i][0];
            if (taxableAfter <= brackets[i][0]) break;
          }
          document.getElementById('rc-extra-tax').textContent = fmt(extra);
          document.getElementById('rc-eff-rate').textContent = effRate.toFixed(1) + '%';
          document.getElementById('rc-tax-before').textContent = fmt(taxBefore);
          document.getElementById('rc-tax-after').textContent = fmt(taxAfter);
          document.getElementById('rc-bracket-note').textContent =
            'Your marginal bracket after conversion is ' + marginalRate + '%. The effective rate on the conversion ('
            + effRate.toFixed(1) + '%) is lower because the progressive system only taxes amounts that fall in each bracket at that bracket\'s rate. Estimate only -- does not include state tax, IRMAA, AMT, or other adjustments.';
          var result = document.getElementById('roth-result');
          result.classList.add('show');
          result.scrollIntoView({behavior:'smooth', block:'nearest'});
        };
      })();
      </script>

      <div class="qa-section">
        <div class="section-eyebrow">How It Is Taxed</div>
        <h2>How a Roth IRA Conversion Is Taxed</h2>
        <p>When you convert pre-tax money from a traditional IRA or 401(k) to a Roth IRA, the converted amount is added to your taxable income for that year and taxed at your ordinary income rates using the standard progressive tax brackets.</p>

        <div class="example-calc">
          <h3>Single filer, $60,000 salary, converts $20,000 traditional IRA to Roth in 2025</h3>
          <div class="example-row"><span class="label">W-2 wages</span><span class="value">$60,000</span></div>
          <div class="example-row"><span class="label">Roth conversion amount added to income</span><span class="value">+ $20,000</span></div>
          <div class="example-row"><span class="label">Total gross income</span><span class="value">$80,000</span></div>
          <div class="example-row"><span class="label">Standard deduction</span><span class="value">- $15,000</span></div>
          <div class="example-row"><span class="label">Taxable income</span><span class="value">$65,000</span></div>
          <div class="example-row"><span class="label">Federal income tax (with conversion)</span><span class="value">$9,660</span></div>
          <div class="example-row"><span class="label">Federal income tax (without conversion)</span><span class="value">$7,460</span></div>
          <div class="example-row total"><span class="label">Estimated extra tax from conversion</span><span class="value">~$2,200</span></div>
          <div class="example-row"><span class="label">Effective rate on the converted $20,000</span><span class="value">~11%</span></div>
        </div>

        <div class="info-callout">
          <p><strong>Progressive brackets mean the rate is lower than it looks.</strong> Even though this filer is in the 22% marginal bracket, the $20,000 conversion is not all taxed at 22%. Most of it falls in the 12% bracket because the first $60,000 of taxable income already fills the lower brackets. The effective rate on just the conversion amount is around 11% in this example.</p>
        </div>
      </div>

      <div class="qa-section">
        <div class="section-eyebrow">When to Convert</div>
        <h2>When a Roth Conversion Makes Sense</h2>

        <table class="facts-table">
          <thead>
            <tr><th>Good Time to Convert</th><th>Why</th></tr>
          </thead>
          <tbody>
            <tr><td>Low income year</td><td>Temporary pay cut, sabbatical, career transition, or early retirement before Social Security. Lower income means lower marginal rate on the conversion.</td></tr>
            <tr><td>Before RMDs begin</td><td>Once you reach age 73, required minimum distributions from traditional IRAs force taxable withdrawals. Converting before RMDs begin reduces future forced income.</td></tr>
            <tr><td>Market downturn</td><td>Converting after a market decline means you convert fewer dollars of value, pay less tax, and get more shares into the Roth that grow tax-free when markets recover.</td></tr>
            <tr><td>Expect higher rates in retirement</td><td>If you believe your tax rate in retirement will be higher than today, paying tax now at a lower rate makes sense.</td></tr>
            <tr><td>Leaving to heirs</td><td>Roth IRAs have no RMDs and heirs inherit tax-free growth. Converting for estate planning purposes can be powerful for high-value accounts.</td></tr>
            <tr class="highlight-row"><td>You can pay tax from outside the IRA</td><td>Paying conversion tax from non-IRA funds preserves the full converted amount inside the Roth for tax-free growth</td></tr>
          </tbody>
        </table>

        <div class="tip-callout">
          <p><strong>Partial conversions are fine.</strong> You do not have to convert your entire traditional IRA at once. Many people do partial conversions each year to fill up a lower tax bracket without pushing income into a higher one. For example, converting just enough to fill the 12% bracket each year before retirement can be highly efficient.</p>
        </div>
      </div>

      <div class="qa-section">
        <div class="section-eyebrow">Pros and Cons</div>
        <h2>Roth Conversion: Advantages and Disadvantages</h2>

        <div class="pro-con-grid">
          <div class="pro-card">
            <h3>Advantages</h3>
            <ul>
              <li>Tax-free growth and withdrawals in retirement</li>
              <li>No required minimum distributions at age 73</li>
              <li>Tax diversification in retirement</li>
              <li>Heirs inherit tax-free</li>
              <li>No income limit to convert</li>
              <li>Flexible -- convert any amount any year</li>
            </ul>
          </div>
          <div class="con-card">
            <h3>Disadvantages</h3>
            <ul>
              <li>Tax due in the year of conversion</li>
              <li>Can push you into a higher bracket</li>
              <li>May affect Medicare premiums (IRMAA)</li>
              <li>May reduce ACA subsidy eligibility</li>
              <li>5-year rule on converted amounts</li>
              <li>Requires cash outside IRA to pay tax ideally</li>
            </ul>
          </div>
        </div>

        <div class="warning-callout">
          <p><strong>Watch for IRMAA.</strong> A large Roth conversion can increase your Medicare Part B and Part D premiums two years later through the Income-Related Monthly Adjustment Amount. In 2025, IRMAA surcharges begin at $106,000 MAGI for single filers and $212,000 for married jointly. Plan large conversions carefully if you are near Medicare age.</p>
        </div>
      </div>

      <div class="qa-section">
        <div class="section-eyebrow">Bracket-Filling Strategy</div>
        <h2>How Much to Convert Each Year: The Bracket-Filling Approach</h2>
        <p>One of the most tax-efficient Roth conversion strategies is to convert just enough each year to fill up your current tax bracket without crossing into the next one. This is especially powerful during low-income years -- early retirement before Social Security, a sabbatical year, or a year with large deductions.</p>

        <table class="facts-table">
          <thead>
            <tr><th>Filing Status</th><th>Fill to Top of 12% Bracket</th><th>Fill to Top of 22% Bracket</th><th>Fill to Top of 24% Bracket</th></tr>
          </thead>
          <tbody>
            <tr><td>Single filer (2025 taxable income room)</td><td>Up to $48,475</td><td>Up to $103,350</td><td>Up to $197,300</td></tr>
            <tr><td>Married filing jointly</td><td>Up to $96,950</td><td>Up to $206,700</td><td>Up to $394,600</td></tr>
            <tr><td>Tax rate paid on conversion</td><td>12%</td><td>22%</td><td>24%</td></tr>
            <tr class="highlight-row"><td>Best for</td><td>Early retirees, low-income years</td><td>Most pre-retirement converters</td><td>High savers with large traditional balances</td></tr>
          </tbody>
        </table>

        <div class="example-calc">
          <h3>Example: Married couple, retired at 62, no Social Security yet, $40,000 other income</h3>
          <div class="example-row"><span class="label">Current taxable income (pension + investments)</span><span class="value">$40,000</span></div>
          <div class="example-row"><span class="label">Top of 12% bracket for MFJ</span><span class="value">$96,950</span></div>
          <div class="example-row"><span class="label">Room to convert at 12%</span><span class="value">$56,950</span></div>
          <div class="example-row"><span class="label">Tax on $56,950 conversion at 12%</span><span class="value">~$6,834</span></div>
          <div class="example-row total"><span class="label">Moved to Roth tax-free forever</span><span class="value">$56,950 (paid from outside IRA)</span></div>
        </div>

        <div class="tip-callout">
          <p><strong>The window closes when Social Security starts.</strong> Once you begin Social Security benefits, up to 85% of those benefits become taxable income, which raises your effective marginal rate and shrinks the conversion room in each bracket. The years between retirement and Social Security are often the best Roth conversion opportunity of a person's financial life.</p>
        </div>
      </div>

      <div class="qa-section">
        <div class="section-eyebrow">The 5-Year Rule</div>
        <h2>The Roth Conversion 5-Year Rule Explained</h2>
        <p>Roth conversions have a separate 5-year holding period from regular Roth contributions. Each conversion creates its own 5-year clock. If you withdraw converted amounts within five years of the conversion and you are under age 59.5, you will owe a 10% early withdrawal penalty on the converted amount.</p>

        <table class="facts-table">
          <thead>
            <tr><th>Roth Money Type</th><th>5-Year Rule</th><th>Penalty If Withdrawn Early</th></tr>
          </thead>
          <tbody>
            <tr><td>Regular Roth contributions</td><td>Always available to withdraw penalty and tax-free (contributions only)</td><td>No penalty on contributions</td></tr>
            <tr><td>Roth conversion amounts</td><td>Each conversion has its own 5-year clock from Jan 1 of conversion year</td><td>10% penalty if under 59.5 and within 5 years</td></tr>
            <tr><td>Roth earnings</td><td>Account must be at least 5 years old AND you must be 59.5+</td><td>Tax + 10% penalty if rules not met</td></tr>
            <tr class="highlight-row"><td>After age 59.5</td><td>5-year clock still matters for earnings, not for conversions</td><td>No penalty after 59.5 regardless of holding period</td></tr>
          </tbody>
        </table>
      </div>

      <div class="qa-section">
        <div class="section-eyebrow">The Pro-Rata Rule</div>
        <h2>The Pro-Rata Rule: Why Non-Deductible IRAs Complicate Conversions</h2>
        <p>If you have a mix of pre-tax (deductible) and after-tax (non-deductible) money in any traditional IRA, the IRS requires you to treat every withdrawal and conversion as coming proportionally from both pools. You cannot choose to convert only your non-deductible contributions tax-free. This is the pro-rata rule, and ignoring it is one of the most expensive mistakes in Roth conversion planning.</p>

        <div class="example-calc">
          <h3>Example: $90,000 pre-tax IRA + $10,000 non-deductible IRA, convert $10,000 to Roth</h3>
          <div class="example-row"><span class="label">Total IRA balance (all accounts combined)</span><span class="value">$100,000</span></div>
          <div class="example-row"><span class="label">After-tax (non-deductible) basis</span><span class="value">$10,000</span></div>
          <div class="example-row"><span class="label">Tax-free percentage of any conversion</span><span class="value">10% ($10K / $100K)</span></div>
          <div class="example-row"><span class="label">Conversion amount</span><span class="value">$10,000</span></div>
          <div class="example-row"><span class="label">Tax-free portion of conversion</span><span class="value">$1,000 (10%)</span></div>
          <div class="example-row total"><span class="label">Taxable portion of conversion</span><span class="value">$9,000 (90%)</span></div>
        </div>

        <div class="warning-callout">
          <p><strong>The backdoor Roth only works cleanly with no pre-existing IRA balance.</strong> High earners who do a backdoor Roth conversion get hit with the pro-rata rule if they have any pre-tax IRA money elsewhere. The cleanest solution is to roll your traditional IRA balance into a current employer 401(k) before doing the backdoor conversion -- 401(k) balances are excluded from the pro-rata calculation.</p>
        </div>

        <table class="facts-table">
          <thead>
            <tr><th>Situation</th><th>Pro-Rata Impact</th></tr>
          </thead>
          <tbody>
            <tr><td>Only pre-tax IRA money</td><td>No issue -- 100% of any conversion is taxable, as expected</td></tr>
            <tr><td>Only non-deductible IRA contributions, no growth</td><td>No issue -- 100% tax-free conversion (classic backdoor Roth)</td></tr>
            <tr><td>Mix of pre-tax and after-tax IRA money</td><td>Pro-rata rule applies -- partial tax on every conversion</td></tr>
            <tr class="highlight-row"><td>Pre-tax 401(k) rolled to IRA before backdoor Roth</td><td>Creates pro-rata problem -- consider rolling into employer plan instead</td></tr>
          </tbody>
        </table>
      </div>

