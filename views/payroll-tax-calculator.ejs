  <div class="page-with-sidebar">
  <main>
    <div class="calc-page">

      <div class="calc-page-header">
        <div class="page-eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
          Paycheck Tax Estimator
        </div>
        <h1>Payroll Tax Calculator</h1>
        <p>Estimate federal withholding, Social Security tax, Medicare tax, optional state withholding, and take-home pay per paycheck for 2025.</p>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block" id="ad-slot-1"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="5205436277"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>
          (function() {
            var ins = document.getElementById('ad-slot-1');
            if (!ins) return;
            var obs = new IntersectionObserver(function(entries) {
              if (entries[0].isIntersecting) {
                (adsbygoogle = window.adsbygoogle || []).push({});
                obs.disconnect();
              }
            }, { rootMargin: '200px' });
            obs.observe(ins);
          })();
        </script>
      </div>

      <div style="margin:0 0 24px;padding:16px 0;border-bottom:1px solid #e5e7eb;">
        <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#16a34a;margin:0 0 10px;">Try next</p>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
        <a href="/income-tax-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">💰</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Income Tax Calculator</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">Estimate your federal tax bill</p>
          </div>
        </a>
        <a href="/tax-refund-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">💵</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Tax Refund Calculator</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">Will you get a refund?</p>
          </div>
        </a>
        <a href="/self-employment-tax-calculator" style="display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;" onmouseover="this.style.borderColor='#16a34a'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:1.3rem;">🧾</span>
          <div>
            <p style="font-size:.8rem;font-weight:700;color:#111827;margin:0 0 2px;">Self-Employment Tax</p>
            <p style="font-size:.72rem;color:#9ca3af;margin:0;">SE tax + deduction</p>
          </div>
        </a>
        </div>
      </div>

      <% if (result) { %>
      <div class="result-card">
        <div class="result-card-header">
          <div class="result-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
          </div>
          <h2>Your Paycheck Estimate</h2>
        </div>
        <div class="result-primary">
          <span class="result-label">Estimated Net Pay</span>
          <span class="result-amount">$<%= typeof result.netPay === 'number' ? result.netPay.toFixed(2) : result.netPay %></span>
        </div>
        <div class="result-grid">
          <div class="result-item">
            <div class="ri-label">Gross Pay</div>
            <div class="ri-value">$<%= typeof result.grossPay === 'number' ? result.grossPay.toFixed(2) : result.grossPay %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Federal Withholding Est.</div>
            <div class="ri-value red">$<%= typeof result.estimatedFederalWithholding === 'number' ? result.estimatedFederalWithholding.toFixed(2) : result.estimatedFederalWithholding %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Social Security Tax</div>
            <div class="ri-value red">$<%= typeof result.socialSecurityTax === 'number' ? result.socialSecurityTax.toFixed(2) : result.socialSecurityTax %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Medicare Tax</div>
            <div class="ri-value red">$<%= typeof result.medicareTax === 'number' ? result.medicareTax.toFixed(2) : result.medicareTax %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">State Withholding Est.</div>
            <div class="ri-value red">$<%= typeof result.stateWithholding === 'number' ? result.stateWithholding.toFixed(2) : result.stateWithholding %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Total Taxes This Check</div>
            <div class="ri-value red">$<%= typeof result.totalTaxes === 'number' ? result.totalTaxes.toFixed(2) : result.totalTaxes %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Est. Annual Net Pay</div>
            <div class="ri-value">$<%= typeof result.estimatedAnnualNetPay === 'number' ? result.estimatedAnnualNetPay.toFixed(2) : result.estimatedAnnualNetPay %></div>
          </div>
          <div class="result-item">
            <div class="ri-label">Additional Medicare Tax</div>
            <div class="ri-value">$<%= typeof result.additionalMedicareTax === 'number' ? result.additionalMedicareTax.toFixed(2) : result.additionalMedicareTax %></div>
          </div>
        </div>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <% } %>

      <div class="calc-card-form">
        <h2>Enter Your Paycheck Information</h2>
        <form method="POST" action="/payroll-tax-calculator">
          <div class="form-grid">
            <div class="form-field">
              <label for="grossPay">Gross Pay Per Paycheck</label>
              <div class="input-wrap"><span class="input-prefix">$</span>
                <input type="number" id="grossPay" name="grossPay" min="0" step="0.01" value="<%= form.grossPay || '' %>" placeholder="2500.00" required>
              </div>
            </div>
            <div class="form-field">
              <label for="payFrequency">Pay Frequency</label>
              <select id="payFrequency" name="payFrequency">
                <option value="weekly" <%= form.payFrequency === 'weekly' ? 'selected' : '' %>>Weekly</option>
                <option value="biweekly" <%= (!form.payFrequency || form.payFrequency === 'biweekly') ? 'selected' : '' %>>Biweekly</option>
                <option value="semimonthly" <%= form.payFrequency === 'semimonthly' ? 'selected' : '' %>>Semi-monthly</option>
                <option value="monthly" <%= form.payFrequency === 'monthly' ? 'selected' : '' %>>Monthly</option>
                <option value="annual" <%= form.payFrequency === 'annual' ? 'selected' : '' %>>Annual</option>
              </select>
            </div>
            <div class="form-field">
              <label for="filingStatus">Filing Status</label>
              <select id="filingStatus" name="filingStatus">
                <option value="single" <%= (!form.filingStatus || form.filingStatus === 'single') ? 'selected' : '' %>>Single</option>
                <option value="marriedJoint" <%= form.filingStatus === 'marriedJoint' ? 'selected' : '' %>>Married Filing Jointly</option>
                <option value="marriedSeparate" <%= form.filingStatus === 'marriedSeparate' ? 'selected' : '' %>>Married Filing Separately</option>
                <option value="headHousehold" <%= form.filingStatus === 'headHousehold' ? 'selected' : '' %>>Head of Household</option>
              </select>
            </div>
            <div class="form-field">
              <label for="preTaxDeductions">Pre-Tax Deductions Per Paycheck</label>
