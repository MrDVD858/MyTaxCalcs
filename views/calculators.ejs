<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pageTitle %> | MyTaxCalcs</title>
  <meta name="description" content="Browse free tax calculators for income tax, tax refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <meta name="google-site-verification" content="TT2j7SglafccBK-Nfk4l1XVIDXEJdSmyQJf2wL9QY0o" />

  <link rel="stylesheet" href="/css/style.css">

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549"
     crossorigin="anonymous"></script>
</head>
<body>
  <header class="small-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-icon">💵</span>
        <span>MyTaxCalcs</span>
      </a>

      <div class="nav-links">
  <a href="/">Home</a>
  <a href="/calculators">Calculators</a>
  <a href="/california-income-tax-calculator">States</a>
  <a href="/about">About</a>
  <a href="/contact">Contact</a>
</div>
    </nav>
  </header>

  <main class="container page-container">
    <section class="page-card">
      <p class="eyebrow dark">Free Tax Tools</p>
      <h1>Tax calculators</h1>
      <p>
        Browse free calculators for federal income tax, tax refunds, self-employment tax,
        capital gains tax, sales tax, payroll tax, and state income tax estimates.
      </p>
    </section>

    <section class="card-grid calculators-directory">
      <a class="card feature-card" href="/income-tax-calculator">
        <div class="icon-box">📊</div>
        <h2>Income Tax Calculator</h2>
        <p>Estimate federal taxable income, tax owed, refund, and effective tax rate.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/tax-refund-calculator">
        <div class="icon-box">💸</div>
        <h2>Tax Refund Calculator</h2>
        <p>Estimate your federal refund or amount owed using withholding, credits, and payments.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/self-employment-tax-calculator">
        <div class="icon-box">🧾</div>
        <h2>Self-Employment Tax Calculator</h2>
        <p>Estimate Social Security and Medicare tax for freelance, contractor, and gig income.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/capital-gains-tax-calculator">
        <div class="icon-box">📈</div>
        <h2>Capital Gains Tax Calculator</h2>
        <p>Estimate short-term and long-term tax on stocks, crypto, real estate, or other asset sales.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/sales-tax-calculator">
        <div class="icon-box">🛒</div>
        <h2>Sales Tax Calculator</h2>
        <p>Estimate sales tax, combined tax rate, discount amount, and final purchase total.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/payroll-tax-calculator">
        <div class="icon-box">💼</div>
        <h2>Payroll Tax Calculator</h2>
        <p>Estimate paycheck withholding, Social Security, Medicare, state withholding, and net pay.</p>
        <span class="card-link">Open Calculator →</span>
      </a>

      <a class="card feature-card" href="/california-income-tax-calculator">
        <div class="icon-box">🌉</div>
        <h2>State Income Tax Calculators</h2>
        <p>Choose from all 50 state income tax calculator pages.</p>
        <span class="card-link">View State Calculators →</span>
      </a>
    </section>
  
    <section class="page-card state-directory-section" id="state-calculators">
      <p class="eyebrow dark">All 50 States</p>
        <h2>State income tax calculators</h2>
        <p>
        Choose your state to estimate federal tax and review state-specific income tax information.
        </p>

        <div class="state-list">
        <% states.forEach(function(state) { %>
        <a href="/<%= state.slug %>-income-tax-calculator"><%= state.name %></a>
        <% }) %>
      </div>
    </section>
  </main>

  <footer>
    <a href="/privacy-policy">Privacy Policy</a>
    <a href="/terms">Terms</a>
    <a href="/disclaimer">Disclaimer</a>
    <a href="/contact">Contact</a>
    <p>© 2026 MyTaxCalcs.com</p>
  </footer>
</body>
</html>
