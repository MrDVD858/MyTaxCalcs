    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Child Tax Credit for 2025?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 2025 Child Tax Credit is up to $2,000 per qualifying child under age 17 at the end of 2025. Up to $1,700 of the credit is refundable as the Additional Child Tax Credit (ACTC) for taxpayers who qualify. The credit begins to phase out at $200,000 of modified AGI for single filers and $400,000 for married filing jointly."
        }
      },
      {
        "@type": "Question",
        "name": "Who qualifies for the Child Tax Credit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To qualify, the child must be under age 17 at the end of the tax year, be your son, daughter, stepchild, foster child, sibling, or descendant of any of these, have lived with you for more than half the year, not have provided more than half of their own support, be a US citizen, national, or resident alien, and have a valid Social Security number."
        }
      },
      {
        "@type": "Question",
        "name": "Will the Child Tax Credit change in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — and it increased. The One Big Beautiful Bill Act (OBBBA), signed July 4, 2025, made the Child Tax Credit permanent and raised the maximum to $2,200 per qualifying child starting with tax year 2025. Phase-out thresholds ($200,000 single / $400,000 MFJ) were also made permanent. Your 2026 return filed in 2027 will reflect the $2,200 amount."
        }
      }
    ]
  }
