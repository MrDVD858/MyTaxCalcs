<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> | MyTaxCalcs</title>
  <meta name="description" content="<%= post.metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= post.ogTitle %>">
  <meta property="og:description" content="<%= post.ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= post.ogTitle %>">
  <meta name="twitter:description" content="<%= post.ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= post.title %>",
    "datePublished": "<%= post.dateISO %>",
    "author": {
      "@type": "Organization",
      "name": "MyTaxCalcs Editorial"
    },
    "publisher": {
      "@type": "Organization",
      "name": "MyTaxCalcs",
      "logo": {
        "@type": "ImageObject",
        "url": "https://mytaxcalcs.com/favicon.png"
      }
    },
    "description": "<%= post.metaDescription %>"
  }
  </script>
  <style>
    .breadcrumb{max-width:1100px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db;font-size:.75rem}
    
    /* Layout Framing Update */
    .article-container{max-width:1100px;margin:0 auto;padding:0 24px 60px;display:grid;grid-template-columns:1fr 300px;gap:40px}
    @media(max-width:900px){.article-container{grid-template-columns:1fr;gap:24px}}
    
    .article-main{min-width:0}
    .post-header{padding:28px 0 24px;border-bottom:1px solid #e5e7eb;margin-bottom:28px}
    .post-category-badge{display:inline-block;font-size:.75rem;font-weight:700;color:#16a34a;background:#ecfdf4;padding:3px 10px;border-radius:6px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}
    .post-header h1{font-size:2.2rem;font-weight:800;line-height:1.25;color:#111827;margin:0 0 14px}
    .post-meta{display:flex;gap:16px;font-size:.85rem;color:#6b7280;flex-wrap:wrap}
    .post-meta strong{color:#374151}
    
    .post-body-content{font-size:1.05rem;line-height:1.75;color:#374151}
    .post-body-content p{margin:0 0 20px}
    .post-body-content h2{font-size:1.4rem;font-weight:800;color:#111827;margin:32px 0 16px;line-height:1.3}
    .post-body-content h3{font-size:1.15rem;font-weight:700;color:#111827;margin:24px 0 12px}
    .post-body-content ul,.post-body-content ol{margin:0 0 24px;padding-left:24px}
    .post-body-content li{margin-bottom:8px}
    .post-body-content strong{color:#111827}
    .post-body-content a{color:#16a34a;text-decoration:none;font-weight:600;border-bottom:1px solid transparent}.post-body-content a:hover{border-color:currentColor}
    
    /* Sticky Sidebar Configuration */
    .article-sidebar{padding-top:28px}
    .sidebar-sticky-wrap{position:sticky;top:24px;display:flex;flex-direction:column;gap:24px}
    .sidebar-widget{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px}
    .sidebar-widget h3{font-size:.9rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#111827;margin:0 0 16px}
    
    .related-tools-list{display:flex;flex-direction:column;gap:10px}
    .tool-link-item{display:flex;align-items:center;justify-content:between;padding:10px 14px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:#374151;font-weight:600;font-size:.88rem;transition:all .15s}
    .tool-link-item:hover{border-color:#16a34a;color:#16a34a;background:#f0fdf4}
    
    .ad-zone{text-align:center;margin:24px 0;min-height:90px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    .sidebar-ad-unit{min-height:250px;display:flex;flex-direction:column;align-items:center}
  </style>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
    </nav>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <a href="/blog">Tax Blog</a>
    <span class="breadcrumb-sep">&#8250;</span>
    <span><%= post.title %></span>
  </nav>

  <main>
    <div class="article-container">
      
      <article class="article-main">
        <div class="post-header">
          <span class="post-category-badge"><%= post.category %></span>
          <h1><%= post.title %></h1>
          <div class="post-meta">
            <span>Published: <strong><%= post.date %></strong></span>
            <span>•</span>
            <span>By <strong><%= post.author %></strong></span>
          </div>
        </div>

        <div class="ad-zone">
          <div class="ad-zone-label">Advertisement</div>
          <ins class="adsbygoogle" style="display:block"
            data-ad-client="ca-pub-5193834725888549"
            data-ad-slot="5205436277"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <div class="post-body-content">
          <%- post.content %>
        </div>

        <div class="ad-zone" style="margin-top:32px">
          <div class="ad-zone-label">Advertisement</div>
          <ins class="adsbygoogle" style="display:block"
            data-ad-client="ca-pub-5193834725888549"
            data-ad-slot="4212978293"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </article>

      <aside class="article-sidebar">
        <div class="sidebar-sticky-wrap">
          
          <div class="sidebar-widget sidebar-ad-unit">
            <div class="ad-zone-label">Advertisement</div>
            <ins class="adsbygoogle" style="display:block"
              data-ad-client="ca-pub-5193834725888549"
              data-ad-slot="5205436277"
              data-ad-format="auto"
              data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
          </div>

          <% if (post.relatedLinks && post.relatedLinks.length > 0) { %>
            <div class="sidebar-widget">
              <h3>Related Tax Tools</h3>
              <div class="related-tools-list">
                <% post.relatedLinks.forEach(function(link) { %>
                  <a href="<%= link.href %>" class="tool-link-item">
                    <span><%= link.label %></span>
                    <span style="color:#16a34a">&#8594;</span>
                  </a>
                <% }) %>
              </div>
            </div>
          <% } %>

        </div>
      </aside>

    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Tax Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom"><p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p></div>
    </div>
  </footer>

</body>
</html>