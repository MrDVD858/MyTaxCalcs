<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= (typeof post !== 'undefined' && post.title) ? post.title : 'Tax Blog' %> | MyTaxCalcs</title>
  <meta name="description" content="<%= (typeof post !== 'undefined' && post.metaDescription) ? post.metaDescription : '' %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= (typeof post !== 'undefined' && post.ogTitle) ? post.ogTitle : '' %>">
  <meta property="og:description" content="<%= (typeof post !== 'undefined' && post.ogDescription) ? post.ogDescription : '' %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta property="og:image" content="https://mytaxcalcs.com/images/og-default.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= (typeof post !== 'undefined' && post.ogTitle) ? post.ogTitle : '' %>">
  <meta name="twitter:description" content="<%= (typeof post !== 'undefined' && post.ogDescription) ? post.ogDescription : '' %>">
  <meta name="twitter:image" content="https://mytaxcalcs.com/images/og-default.png">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>

  <style>
    .breadcrumb{max-width:1140px;margin:0 auto;padding:14px 28px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db;font-size:.75rem}
    .article-container{max-width:1140px;margin:0 auto;padding:0 28px 60px;display:grid;grid-template-columns:1fr 284px;gap:34px}
    @media(max-width:900px){.article-container{grid-template-columns:1fr;gap:24px}}
    .article-main{min-width:0}
    .post-header{padding:24px 0 22px;border-bottom:1px solid #e5e7eb;margin-bottom:26px}
    .post-category-badge{display:inline-block;font-size:.67rem;font-weight:700;color:#15803d;background:#dcfce7;padding:3px 9px;border-radius:5px;margin-bottom:11px;text-transform:uppercase;letter-spacing:.08em}
    .post-header h1{font-size:clamp(1.5rem,4vw,2.15rem);font-weight:800;line-height:1.22;color:#111827;margin:0 0 13px;letter-spacing:-.028em}
    .post-meta{display:flex;gap:14px;font-size:.84rem;color:#5b6778;flex-wrap:wrap;align-items:center}
    .post-meta strong{color:#374151;font-weight:600}
    .post-body-content{font-size:1.04rem;line-height:1.8;color:#374151}
    .post-body-content p{margin:0 0 20px}
    .post-body-content h2{font-size:1.38rem;font-weight:800;color:#111827;margin:34px 0 14px;line-height:1.25;letter-spacing:-.022em}
    .post-body-content h3{font-size:1.08rem;font-weight:700;color:#111827;margin:24px 0 10px;letter-spacing:-.012em}
    .post-body-content ul,.post-body-content ol{margin:0 0 22px;padding-left:24px}
    .post-body-content li{margin-bottom:8px;line-height:1.68}
    .post-body-content strong{color:#111827;font-weight:700}
    .post-body-content a{color:#16a34a;text-decoration:none;font-weight:600;border-bottom:1px solid transparent}.post-body-content a:hover{border-color:currentColor}
    .post-body-content table{width:100%;border-collapse:collapse;margin:0 0 22px;font-size:.93rem}
    .post-body-content th{background:#f3f4f6;padding:.6rem 1rem;text-align:left;font-weight:700;color:#374151;border-bottom:1px solid #e5e7eb}
    .post-body-content td{padding:.6rem 1rem;border-bottom:1px solid #f3f4f6;color:#111827}
    .post-body-content tr:last-child td{border-bottom:none}
    .article-sidebar{padding-top:26px}
    .sidebar-sticky-wrap{position:sticky;top:24px;display:flex;flex-direction:column;gap:14px}
    .sidebar-widget{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:18px 20px}
    .sidebar-widget h3{font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#374151;margin:0 0 12px}
    .related-tools-list{display:flex;flex-direction:column;gap:6px}
    .tool-link-item{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border:1px solid #e9edf2;border-radius:9px;text-decoration:none;color:#374151;font-weight:600;font-size:.88rem;transition:all .14s;background:#fafafa}
    .tool-link-item:hover{border-color:#16a34a;color:#15803d;background:#f0fdf4;transform:translateX(2px)}
    .tool-link-arrow{color:#16a34a;font-size:1rem;line-height:1}
    .ad-zone{text-align:center;margin:8px 0;}
    .ad-zone-label{font-size:.67rem;color:#b0bbc9;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
    .sidebar-ad-unit{min-height:0;display:flex;flex-direction:column;align-items:center;background:transparent;border:none}
    .tool-link-item{background:#161e2e;border-color:rgba(255,255,255,0.08);color:#8ba3c7;border-radius:9px;font-size:.86rem}
    .tool-link-item:hover{background:rgba(34,197,94,0.08);border-color:rgba(34,197,94,0.22);color:#fff;transform:translateX(3px)}
    .tool-link-arrow{color:#4ade80}
    .sidebar-widget{background:#0d1117;border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:18px 20px}
    .sidebar-widget h3{font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em;color:#4ade80;margin:0 0 12px}
    .article-container{padding-top:20px}
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= (typeof post !== 'undefined' && post.title) ? post.title : '' %>",
    "description": "<%= (typeof post !== 'undefined' && post.metaDescription) ? post.metaDescription : '' %>",
    "url": "<%= canonical %>",
    "datePublished": "<%= (typeof post !== 'undefined' && post.dateISO) ? post.dateISO : '' %>",
    "dateModified": "<%= (typeof post !== 'undefined' && post.dateISO) ? post.dateISO : '' %>",
    "author": {
      "@type": "Person",
      "name": "MyTaxCalcs Editorial Team",
      "url": "https://mytaxcalcs.com/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "MyTaxCalcs",
      "url": "https://mytaxcalcs.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://mytaxcalcs.com/favicon.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "<%= canonical %>"
    }
  }
  </script>
  <script>
    (function() {
      function collapseEmptyAdZones() {
        document.querySelectorAll('.ad-zone').forEach(function(zone) {
          var ins = zone.querySelector('ins.adsbygoogle');
          if (!ins) return;
          var status = ins.getAttribute('data-ad-status');
          var h = ins.offsetHeight || parseInt((ins.style.height || '0'), 10);
          if (status === 'unfilled' || h === 0) {
            zone.style.cssText = 'margin:0!important;padding:0!important;min-height:0!important;line-height:0!important;overflow:hidden';
          }
        });
      }
      window.addEventListener('load', function() {
        setTimeout(collapseEmptyAdZones, 1000);
        setTimeout(collapseEmptyAdZones, 2500);
      });
      if (window.MutationObserver) {
        var mo = new MutationObserver(function(muts) {
          muts.forEach(function(m) {
            if (m.type === 'attributes' && m.attributeName === 'data-ad-status') {
              collapseEmptyAdZones();
            }
          });
        });
        document.addEventListener('DOMContentLoaded', function() {
          document.querySelectorAll('ins.adsbygoogle').forEach(function(ins) {
            mo.observe(ins, { attributes: true });
          });
        });
      }
    })();
  </script>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-cta" href="/calculators">All Calculators</a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="nav-mobile-drawer" id="nav-mobile-drawer" role="navigation" aria-label="Mobile navigation">
      <div class="nav-mobile-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </div>
      <a class="nav-mobile-cta" href="/calculators">All Calculators</a>
    </div>
  </header>


  <section class="article-hero">
    <div class="article-hero-bg"></div>
    <div class="article-hero-glow"></div>
    <div class="article-hero-inner">
      <nav class="hero-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="hbc-sep">&#8250;</span>
        <a href="/blog">Tax Blog</a>
        <span class="hbc-sep">&#8250;</span>
        <span class="hbc-current"><%= (typeof post !== 'undefined' && post.title) ? post.title.substring(0, 50) + (post.title.length > 50 ? '...' : '') : 'Article' %></span>
      </nav>
      <% if (typeof post !== 'undefined' && post) { %>
      <div class="article-cat-badge"><%= post.category || 'Tax Insights' %></div>
      <h1><%= post.title %></h1>
      <div class="article-hero-meta">
        <span>Published: <strong><%= post.date %></strong></span>
        <div class="article-hero-sep"></div>
        <span>By <strong><%= post.author %></strong></span>
      </div>
      <% } %>
    </div>
  </section>

  <div class="page-with-sidebar">
  <main>
    <div class="article-container">

      <% if (typeof post !== 'undefined' && post) { %>
      <article class="article-main">

        <div class="ad-zone">
          <div class="ad-zone-label">Advertisement</div>
          <ins class="adsbygoogle" style="display:block"
            data-ad-client="ca-pub-5193834725888549"
            data-ad-slot="5205436277"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

        <div class="post-body-content">
          <%- post.content %>
        </div>

        <div class="ad-zone" style="margin-top:32px">
          <div class="ad-zone-label">Advertisement</div>
          <ins class="adsbygoogle" style="display:block"
            data-ad-client="ca-pub-5193834725888549"
            data-ad-slot="4212978293"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </article>
      <% } else { %>
        <article class="article-main">
          <div class="post-header">
            <h1>Article Content Temporarily Unavailable</h1>
          </div>
          <p>Please return to our <a href="/blog">Tax Blog Index</a> to select another article.</p>
        </article>
      <% } %>

      <aside class="article-sidebar">
        <div class="sidebar-sticky-wrap">

          <div class="sidebar-widget sidebar-ad-unit">
            <div class="ad-zone-label">Advertisement</div>
            <ins class="adsbygoogle" style="display:block"
              data-ad-client="ca-pub-5193834725888549"
              data-ad-slot="5205436277"
              data-ad-format="auto"
              data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
          </div>

          <div class="sidebar-widget" style="background:#0d1117;border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:18px 20px">
            <h3 style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em;color:#4ade80;margin:0 0 12px">Related Tax Tools</h3>
            <div class="related-tools-list">
              <a href="/income-tax-calculator" class="tool-link-item">
                <span>Income Tax Calculator</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
              <a href="/tax-refund-calculator" class="tool-link-item">
                <span>Tax Refund Calculator</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
              <a href="/payroll-tax-calculator" class="tool-link-item">
                <span>Payroll Tax Calculator</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
              <a href="/self-employment-tax-calculator" class="tool-link-item">
                <span>Self-Employment Tax</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
              <a href="/capital-gains-tax-calculator" class="tool-link-item">
                <span>Capital Gains Tax</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
              <a href="/sales-tax-calculator" class="tool-link-item">
                <span>Sales Tax Calculator</span>
                <span class="tool-link-arrow">&#8594;</span>
              </a>
            </div>
          </div>

          <div class="sidebar-widget" style="background:#f0fdf4;border-color:#d1fae5">
            <h3 style="color:#15803d">Quick Reference</h3>
            <div style="display:flex;flex-direction:column;gap:6px">
              <a href="/tax-brackets-2025" style="font-size:.85rem;color:#374151;text-decoration:none;padding:6px 0;border-bottom:1px solid #d1fae5;font-weight:500;display:flex;justify-content:space-between" onmouseover="this.style.color='#15803d'" onmouseout="this.style.color='#374151'">2025 Tax Brackets <span style="color:#16a34a">&#8594;</span></a>
              <a href="/standard-deduction-2025" style="font-size:.85rem;color:#374151;text-decoration:none;padding:6px 0;border-bottom:1px solid #d1fae5;font-weight:500;display:flex;justify-content:space-between" onmouseover="this.style.color='#15803d'" onmouseout="this.style.color='#374151'">Standard Deduction 2025 <span style="color:#16a34a">&#8594;</span></a>
              <a href="/child-tax-credit-2025" style="font-size:.85rem;color:#374151;text-decoration:none;padding:6px 0;border-bottom:1px solid #d1fae5;font-weight:500;display:flex;justify-content:space-between" onmouseover="this.style.color='#15803d'" onmouseout="this.style.color='#374151'">Child Tax Credit 2025 <span style="color:#16a34a">&#8594;</span></a>
              <a href="/401k-contribution-limits-2025" style="font-size:.85rem;color:#374151;text-decoration:none;padding:6px 0;font-weight:500;display:flex;justify-content:space-between" onmouseover="this.style.color='#15803d'" onmouseout="this.style.color='#374151'">401(k) Limits 2025 <span style="color:#16a34a">&#8594;</span></a>
            </div>
          </div>

        </div>
      </aside>

    </div>
  </main>
  <aside class="sidebar-ad-col" aria-label="Advertisement" aria-hidden="true">
    <div class="sidebar-ad-inner">
      <p class="sidebar-ad-label">Ad</p>
      <ins class="adsbygoogle"
           style="display:block;width:160px;min-height:600px"
           data-ad-client="ca-pub-5193834725888549"
           data-ad-slot="4041103773"
           data-ad-format="auto"
           data-full-width-responsive="false"></ins>
      <script>
        (function(){
          var ins=document.currentScript.previousElementSibling;
          var io=new IntersectionObserver(function(entries,observer){
            if(entries[0].isIntersecting){
              (adsbygoogle=window.adsbygoogle||[]).push({});
              observer.disconnect();
            }
          },{rootMargin:'200px'});
          io.observe(ins);
        })();
      </script>
    </div>
  </aside>
</div>


  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo"><span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>MyTaxCalcs</a>
