<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %> | MyTaxCalcs</title>
  <meta name="description" content="<%= post.metaDescription %>">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= post.ogTitle %>">
  <meta property="og:description" content="<%= post.ogDescription %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="MyTaxCalcs">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= post.ogTitle %>">
  <meta name="twitter:description" content="<%= post.ogDescription %>">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FS9HCDT0D7"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-FS9HCDT0D7');</script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5193834725888549" crossorigin="anonymous"></script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "<%= post.title %>",
    "datePublished": "<%= post.dateISO %>",
    "dateModified": "<%= post.dateISO %>",
    "author": { "@type": "Organization", "name": "MyTaxCalcs" },
    "publisher": { "@type": "Organization", "name": "MyTaxCalcs", "url": "https://mytaxcalcs.com" },
    "description": "<%= post.metaDescription %>",
    "url": "https://mytaxcalcs.com/blog/<%= post.slug %>"
  }
  </script>
  <style>
    .breadcrumb{max-width:860px;margin:0 auto;padding:14px 24px 0;font-size:.8rem;color:#6b7280;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .breadcrumb a{color:#16a34a;text-decoration:none}.breadcrumb a:hover{text-decoration:underline}
    .breadcrumb-sep{color:#d1d5db}
    .post-page{max-width:860px;margin:0 auto;padding:0 24px 60px}
    .post-header{padding:32px 0 28px;border-bottom:1px solid #e5e7eb;margin-bottom:32px}
    .post-category{display:inline-block;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#16a34a;background:#ecfdf5;border-radius:20px;padding:3px 10px;margin-bottom:12px}
    .post-header h1{font-size:1.9rem;font-weight:800;line-height:1.25;margin:0 0 14px;color:#111827}
    .post-meta{display:flex;align-items:center;gap:10px;font-size:.82rem;color:#9ca3af;flex-wrap:wrap}
    .post-meta-dot{width:3px;height:3px;border-radius:50%;background:#d1d5db}
    .post-meta .source-badge{background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:6px;padding:2px 8px;font-size:.72rem;font-weight:600}
    .post-body{font-size:.97rem;color:#374151;line-height:1.75}
    .post-body h2{font-size:1.3rem;font-weight:800;color:#111827;margin:2rem 0 .75rem}
    .post-body h3{font-size:1.05rem;font-weight:700;color:#111827;margin:1.5rem 0 .5rem}
    .post-body p{margin:0 0 1rem}
    .post-body ul,.post-body ol{margin:0 0 1rem;padding-left:1.4rem}
    .post-body li{margin-bottom:.4rem}
    .post-body a{color:#16a34a;text-decoration:underline}
    .post-body a:hover{color:#15803d}
    .post-body strong{color:#111827;font-weight:700}
    .post-body table{width:100%;border-collapse:collapse;margin:1rem 0 1.5rem;background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;font-size:.88rem}
    .post-body th{background:#f9fafb;padding:10px 14px;text-align:left;font-size:.78rem;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.05em;border-bottom:1px solid #e5e7eb}
    .post-body td{padding:11px 14px;border-bottom:1px solid #f3f4f6;color:#374151}
    .post-body tr:last-child td{border-bottom:none}
    .ad-zone{text-align:center;margin:32px 0;min-height:90px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
    .related-section{margin:40px 0 0;padding-top:32px;border-top:1px solid #e5e7eb}
    .related-section h2{font-size:1.1rem;font-weight:700;color:#111827;margin:0 0 16px}
    .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    @media(max-width:640px){.related-grid{grid-template-columns:1fr}}
    .related-card{background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:14px 16px;text-decoration:none;color:inherit;transition:border-color .15s,box-shadow .15s}
    .related-card:hover{border-color:#16a34a;box-shadow:0 3px 10px rgba(22,163,74,.08)}
    .related-card strong{display:block;font-size:.88rem;font-weight:700;color:#111827;margin-bottom:4px}
    .related-card span{font-size:.8rem;color:#6b7280;line-height:1.45}
    .back-to-blog{display:inline-flex;align-items:center;gap:6px;font-size:.85rem;font-weight:600;color:#16a34a;text-decoration:none;margin-bottom:24px}
    .back-to-blog:hover{text-decoration:underline}
    .disclaimer-box{background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;padding:16px 20px;margin-top:40px;display:flex;gap:10px;align-items:flex-start}
    .disclaimer-box svg{min-width:18px;color:#9ca3af;margin-top:1px}
    .disclaimer-box p{font-size:.82rem;color:#6b7280;margin:0;line-height:1.55}
  </style>
</head>
<body>

  <header class="site-header">
    <nav class="nav">
      <a href="/" class="logo">
        <span class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/>
            <rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/>
            <rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/>
          </svg>
        </span>
        <span>MyTaxCalcs</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/calculators">Calculators</a>
        <a href="/states">States</a>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </div>
      <a class="nav-cta" href="/income-tax-calculator">Get Started</a>
    </nav>
  </header>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/blog">Blog</a>
    <span class="breadcrumb-sep">›</span>
    <span><%= post.title %></span>
  </nav>

  <main>
    <div class="post-page">

      <a class="back-to-blog" href="/blog">
        ← Back to Tax Blog
      </a>

      <div class="post-header">
        <span class="post-category"><%= post.category %></span>
        <h1><%= post.title %></h1>
        <div class="post-meta">
          <span><%= post.date %></span>
          <span class="post-meta-dot"></span>
          <span><%= post.author %></span>
          <span class="post-meta-dot"></span>
          <span class="source-badge">IRS-Sourced</span>
        </div>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="post-body">
        <%- post.content %>
      </div>

      <div class="ad-zone">
        <div class="ad-zone-label">Advertisement</div>
        <ins class="adsbygoogle" style="display:block"
          data-ad-client="ca-pub-5193834725888549"
          data-ad-slot="4212978293"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="related-section">
        <h2>Related Calculators & Guides</h2>
        <div class="related-grid">
          <% post.relatedLinks.forEach(function(link) { %>
            <a class="related-card" href="<%= link.href %>">
              <strong><%= link.label %></strong>
              <span>Free calculator or guide →</span>
            </a>
          <% }) %>
        </div>
      </div>

      <div class="disclaimer-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p><strong>Disclaimer:</strong> This article is for educational purposes only and is not tax, legal, or financial advice. Tax laws are complex and individual situations vary. Always consult a qualified tax professional before making tax decisions. All figures are sourced from official IRS publications and are accurate as of the date of publication.</p>
      </div>

    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <span class="logo-mark"><svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="1" y="1" width="8" height="8" rx="2" fill="#22c55e"/><rect x="11" y="1" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="1" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.5"/><rect x="11" y="11" width="8" height="8" rx="2" fill="#22c55e" opacity="0.25"/></svg></span>
            MyTaxCalcs
          </a>
          <p>Free tax calculators for income tax, refunds, self-employment tax, capital gains tax, sales tax, payroll tax, and state income tax estimates.</p>
        </div>
        <div class="footer-column">
          <h3>Tax Calculators</h3>
          <a href="/calculators">All Calculators</a>
          <a href="/income-tax-calculator">Income Tax Calculator</a>
          <a href="/tax-refund-calculator">Tax Refund Calculator</a>
          <a href="/self-employment-tax-calculator">Self-Employment Tax</a>
          <a href="/capital-gains-tax-calculator">Capital Gains Tax</a>
          <a href="/sales-tax-calculator">Sales Tax Calculator</a>
          <a href="/payroll-tax-calculator">Payroll Tax Calculator</a>
        </div>
        <div class="footer-column">
          <h3>Site Links</h3>
          <a href="/states">State Tax Calculators</a>
          <a href="/blog">Tax Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms</a>
          <a href="/disclaimer">Disclaimer</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&#169; 2026 MyTaxCalcs.com. Estimates only. Not tax, legal, accounting, or financial advice.</p>
      </div>
    </div>
  </footer>

</body>
</html>
