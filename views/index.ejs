      <div class="calc-grid">
        <a href="/income-tax-calculator" class="calc-card">
          <div class="card-icon-wrap" style="background:#ecfdf5;color:#16a34a;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M7 8h4M7 12h8"/></svg>
