      <div class="calc-grid" style="margin-bottom:12px">
        <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
          <% posts.slice(0,3).forEach(function(post) { %>
            <a href="/blog/<%= post.slug %>" class="calc-card">
