  <style>
    .hero{background:linear-gradient(135deg,#f0fdf4 0%,#e8f5e9 100%);padding:80px 24px 60px;text-align:center;border-bottom:1px solid #e5e7eb}
    .hero-inner{max-width:800px;margin:0 auto}
    .hero h1{font-size:clamp(1.9rem,5vw,2.8rem);font-weight:800;color:#111827;margin:0 0 16px;line-height:1.15}
    .hero p{font-size:1.15rem;color:#4b5563;margin:0 0 28px;line-height:1.6}
    .hero-cta-group{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .hero-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-size:1rem;font-weight:700;border-radius:10px;text-decoration:none;transition:all .15s}
    .hero-btn.primary{background:#16a34a;color:#fff}.hero-btn.primary:hover{background:#15803d;transform:translateY(-1px)}
    .hero-btn.secondary{background:#fff;color:#374151;border:1px solid #d1d5db}.hero-btn.secondary:hover{background:#f9fafb;border-color:#c5c7c9}
    .home-container{max-width:1000px;margin:0 auto;padding:48px 24px 60px}
    .section-title-wrap{margin-bottom:28px}
    .section-eyebrow{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#16a34a;margin-bottom:6px;display:block}
    .section-title-wrap h2{font-size:1.6rem;font-weight:800;color:#111827;margin:0 0 6px}
    .section-title-wrap p{font-size:.95rem;color:#6b7280;margin:0}
    .calc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
    @media(max-width:768px){.calc-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:480px){.calc-grid{grid-template-columns:1fr}}
    .calc-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;text-decoration:none;color:inherit;transition:all .2s;display:flex;flex-direction:column;box-shadow:0 1px 3px rgba(0,0,0,.02)}
    .calc-card:hover{border-color:#16a34a;box-shadow:0 10px 25px rgba(22,163,74,.06);transform:translateY(-2px)}
    .card-icon-wrap{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px}
    .calc-card h3{font-size:1.1rem;font-weight:700;color:#111827;margin:0 0 8px}
    .calc-card p{font-size:.88rem;color:#6b7280;line-height:1.5;margin:0 0 16px;flex-grow:1}
    .card-link{font-size:.85rem;font-weight:700;color:#16a34a;display:inline-flex;align-items:center;gap:4px}
    .card-link svg{transition:transform .15s}.calc-card:hover .card-link svg{transform:translateX(2px)}
    .states-preview-box{background:#f9fafb;border:1px solid #e5e7eb;border-radius:20px;padding:32px;margin-bottom:48px;display:grid;grid-template-columns:1.2fr 2fr;gap:40px;align-items:center}
    @media(max-width:768px){.states-preview-box{grid-template-columns:1fr;gap:24px;padding:24px}}
    .states-preview-info h2{font-size:1.5rem;font-weight:800;color:#111827;margin:0 0 10px}
    .states-preview-info p{font-size:.95rem;color:#6b7280;line-height:1.6;margin:0 0 20px}
    .state-tags{display:flex;flex-wrap:wrap;gap:8px}
    .state-tag{font-size:.82rem;font-weight:500;color:#374151;background:#fff;border:1px solid #d1d5db;border-radius:8px;padding:6px 12px;text-decoration:none;transition:all .15s}
    .state-tag:hover{border-color:#16a34a;color:#16a34a;background:#f0fdf4}
    .view-all-states-link{font-size:.9rem;font-weight:700;color:#16a34a;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-top:12px}
    .view-all-states-link:hover{text-decoration:underline}
    .features-section{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;border-top:1px solid #e5e7eb;padding-top:48px}
    @media(max-width:768px){.features-section{grid-template-columns:1fr}}
    .how-it-works-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
    @media(max-width:768px){.how-it-works-grid{grid-template-columns:1fr;gap:24px}}
    .feature-item h3{font-size:1rem;font-weight:700;color:#111827;margin:0 0 8px;display:flex;align-items:center;gap:8px}
    .feature-item p{font-size:.88rem;color:#6b7280;line-height:1.6;margin:0}
    .feature-icon{color:#16a34a;display:flex;align-items:center}
    .ad-zone{text-align:center;margin:28px 0;min-height:120px}
    .ad-zone-label{font-size:.7rem;color:#9ca3af;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
  </style>
