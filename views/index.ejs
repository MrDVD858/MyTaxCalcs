  <script>
    (function() {
      function collapseEmptyAdZones() {
        document.querySelectorAll('.ad-zone').forEach(function(zone) {
          var ins = zone.querySelector('ins.adsbygoogle');
          if (!ins) return;
          var status = ins.getAttribute('data-ad-status');
          var h = ins.offsetHeight || parseInt((ins.style.height || '0'), 10);
          if (status === 'unfilled' || h === 0) {
            zone.style.cssText = 'margin:0!important;padding:0!important;min-height:0!important;line-height:0!important;overflow:hidden';
          }
        });
      }
      // Fast check: 1s after load covers most blocked/unfilled cases
      window.addEventListener('load', function() {
        setTimeout(collapseEmptyAdZones, 1000);
        setTimeout(collapseEmptyAdZones, 2500);
      });
      // Watch for AdSense setting data-ad-status on ins elements
      if (window.MutationObserver) {
        var mo = new MutationObserver(function(muts) {
          muts.forEach(function(m) {
            if (m.type === 'attributes' && m.attributeName === 'data-ad-status') {
              collapseEmptyAdZones();
            }
          });
        });
        document.addEventListener('DOMContentLoaded', function() {
          document.querySelectorAll('ins.adsbygoogle').forEach(function(ins) {
            mo.observe(ins, { attributes: true });
          });
        });
      }
    })();
  </script>
