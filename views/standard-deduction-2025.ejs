        "@type": "Question",
        "name": "Should I take the standard deduction or itemize?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Take whichever is larger. If your total itemized deductions exceed the standard deduction for your filing status, itemizing saves more tax. Most taxpayers take the standard deduction."
        }
      }
